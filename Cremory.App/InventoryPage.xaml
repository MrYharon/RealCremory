<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Cremory.App.InventoryPage"
             Title="Stocks">

    <Grid RowDefinitions="Auto, *" Padding="20" RowSpacing="16" BackgroundColor="{StaticResource Gray50}">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" ColumnSpacing="12">
            <VerticalStackLayout>
                <Label Text="Bakery Stocks" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Gray900}"/>
                <Label Text="Live updates from inventory database" FontSize="13" TextColor="{StaticResource Gray500}" Margin="0,4,0,0"/>
            </VerticalStackLayout>
            <Button Grid.Column="1" Text="Refresh" Clicked="OnRefreshClicked" 
                    BackgroundColor="{StaticResource Primary}" TextColor="White" 
                    VerticalOptions="End" FontAttributes="Bold" HeightRequest="40" Padding="16,0"/>
        </Grid>

        <!-- Stocks List -->
        <CollectionView Grid.Row="1" x:Name="IngredientsCollectionView">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" 
                            Stroke="{StaticResource Gray200}" Padding="16" Margin="0,0,0,12" 
                            BackgroundColor="White">
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto" RowSpacing="8">

                            <!-- Product Name -->
                            <Label Grid.Row="0" Grid.Column="0" Text="{Binding Name}" FontSize="18" 
                                   FontAttributes="Bold" TextColor="{StaticResource Gray900}"/>

                            <!-- Unit Info -->
                            <Label Grid.Row="1" Grid.Column="0" Text="{Binding Unit, StringFormat='Unit: {0}'}" 
                                   FontSize="12" TextColor="{StaticResource Gray500}" Margin="0,4,0,0"/>

                            <!-- Status Badge -->
                            <StackLayout Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" 
                                        VerticalOptions="Center" Spacing="4">
                                <Label Text="{Binding StockQuantity}" FontSize="22" FontAttributes="Bold" 
                                       TextColor="{StaticResource Primary}" HorizontalOptions="End"/>
                                <Label Text="{Binding Unit}" FontSize="12" TextColor="{StaticResource Gray600}" 
                                       HorizontalOptions="End"/>
                            </StackLayout>

                            <!-- Stock Level Indicator -->
                            <Border Grid.Row="2" Grid.ColumnSpan="2" StrokeShape="RoundRectangle 8" 
                                   BackgroundColor="{StaticResource Gray100}" Padding="12" Stroke="Transparent" Margin="0,4,0,0">
                                <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                                    <ProgressBar Grid.Column="0" Progress="{Binding StockPercentage}" 
                                               ProgressColor="{StaticResource Success}" HeightRequest="6" 
                                               VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding StockPercentage, StringFormat='{0:P0}'}" 
                                           FontSize="11" TextColor="{StaticResource Gray600}" 
                                           HorizontalOptions="End" VerticalOptions="Center"/>.
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
