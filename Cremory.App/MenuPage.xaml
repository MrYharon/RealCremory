<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Cremory.App.Models"
             xmlns:local="clr-namespace:Cremory.App"
             x:Class="Cremory.App.MenuPage"
             Title="Menu"
             BackgroundColor="{StaticResource Gray50}">

    <RefreshView x:Name="MenuRefreshView" Refreshing="OnRefreshing" RefreshColor="{StaticResource Primary}">
    <Grid RowDefinitions="Auto, *" Padding="20" RowSpacing="16">
        <VerticalStackLayout Grid.Row="0" Spacing="6">
            <Label Text="The Cremory Menu" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Gray900}"/>
            <Label Text="Browse our full selection of Basque Cheesecakes and Korean Cream Cheese Breads"
                   FontSize="13" TextColor="{StaticResource Gray500}"/>
        </VerticalStackLayout>

        <ActivityIndicator Grid.Row="1" x:Name="LoadingIndicator" IsRunning="False" IsVisible="False"
                           Color="{StaticResource Primary}" VerticalOptions="Center" HorizontalOptions="Center"/>

        <CollectionView Grid.Row="1" x:Name="MenuCollectionView" IsGrouped="True">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                    <Label Text="Menu is empty" FontSize="20" FontAttributes="Bold"
                           TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                    <Label Text="Add products to see the full menu here" FontSize="14"
                           TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="local:CategoryGroup">
                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="{StaticResource Primary}"
                            Padding="16" Margin="0,8,0,4" Stroke="Transparent">
                        <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold"
                               TextColor="White"/>
                    </Border>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:MenuItemDto">
                    <Border StrokeShape="RoundRectangle 10" StrokeThickness="1"
                            Stroke="{StaticResource Gray200}" Padding="14" Margin="0,0,0,8"
                            BackgroundColor="White">
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" RowSpacing="6">
                            <Label Grid.Row="0" Grid.Column="0" FontSize="15" FontAttributes="Bold"
                                   TextColor="{StaticResource Gray900}">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}{0} — {1}">
                                        <Binding Path="Variant"/>
                                        <Binding Path="Flavor"/>
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                            <Label Grid.Row="0" Grid.Column="1" FontSize="18" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}" HorizontalOptions="End"
                                   Text="{Binding BasePrice, StringFormat='₱{0:N0}'}"/>
                            <Label Grid.Row="1" Grid.ColumnSpan="2"
                                   Text="{Binding AddOnDescription}"
                                   FontSize="11" TextColor="{StaticResource Gray500}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
    </RefreshView>

</ContentPage>
