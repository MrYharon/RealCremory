<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Cremory.App"
             xmlns:models="clr-namespace:Cremory.App.Models"
             x:Class="Cremory.App.RecipeFormPage"
             x:DataType="local:RecipeFormPage"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource Gray50}">

    <Grid RowDefinitions="*, Auto" Padding="20" RowSpacing="16">
        <ScrollView>
            <VerticalStackLayout Spacing="16">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Recipe Name" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource Gray600}"/>
                    <Border StrokeShape="RoundRectangle 8" BackgroundColor="White" Padding="12,8" Stroke="{StaticResource Gray200}">
                        <Entry x:Name="NameEntry" Placeholder="e.g. Classic Basque Cheesecake" FontSize="15"
                               TextColor="{StaticResource Gray900}" PlaceholderColor="{StaticResource Gray400}"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Selling Price (₱)" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource Gray600}"/>
                    <Border StrokeShape="RoundRectangle 8" BackgroundColor="White" Padding="12,8" Stroke="{StaticResource Gray200}">
                        <Entry x:Name="PriceEntry" Placeholder="0" Keyboard="Numeric" FontSize="15"
                               TextColor="{StaticResource Gray900}" PlaceholderColor="{StaticResource Gray400}"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Description (optional)" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource Gray600}"/>
                    <Border StrokeShape="RoundRectangle 8" BackgroundColor="White" Padding="12,8" Stroke="{StaticResource Gray200}">
                        <Editor x:Name="DescriptionEditor" Placeholder="Brief description of the recipe"
                                FontSize="14" TextColor="{StaticResource Gray900}" PlaceholderColor="{StaticResource Gray400}"
                                AutoSize="TextChanges" HeightRequest="60" BackgroundColor="White"/>
                    </Border>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*, Auto" Padding="0,8">
                    <Label Text="Active" FontSize="15" TextColor="{StaticResource Gray900}" VerticalOptions="Center"/>
                    <Switch x:Name="ActiveSwitch" Grid.Column="1" IsToggled="True" OnColor="{StaticResource Success}"/>
                </Grid>

                <BoxView HeightRequest="1" Color="{StaticResource Gray200}" Margin="0,4"/>

                <Label Text="Ingredients" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource Gray900}"/>
                <Label Text="Add the ingredients needed for this recipe" FontSize="12" TextColor="{StaticResource Gray500}" Margin="0,-8,0,0"/>

                <CollectionView x:Name="IngredientsCollection" HeightRequest="200">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:RecipeIngredient">
                            <SwipeView>
                                <SwipeView.RightItems>
                                    <SwipeItems>
                                        <SwipeItem Text="Remove" BackgroundColor="{StaticResource Danger}"
                                                   Invoked="OnRemoveIngredient"/>
                                    </SwipeItems>
                                </SwipeView.RightItems>
                                <Border StrokeShape="RoundRectangle 8" BackgroundColor="White" Padding="12,10"
                                        Stroke="{StaticResource Gray200}" Margin="0,0,0,6">
                                    <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="8">
                                        <Label Text="{Binding Ingredient.Name}" FontSize="14"
                                               TextColor="{StaticResource Gray800}" VerticalOptions="Center"/>
                                        <Label Grid.Column="1" Text="{Binding Quantity, StringFormat='{0:N1}'}"
                                               FontSize="14" FontAttributes="Bold"
                                               TextColor="{StaticResource Primary}" VerticalOptions="Center"/>
                                        <Label Grid.Column="2" Text="{Binding Ingredient.Unit}"
                                               FontSize="12" TextColor="{StaticResource Gray500}" VerticalOptions="Center"/>
                                    </Grid>
                                </Border>
                            </SwipeView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.EmptyView>
                        <Label Text="No ingredients added yet" FontSize="13" TextColor="{StaticResource Gray400}"
                               HorizontalTextAlignment="Center" Padding="0,20"/>
                    </CollectionView.EmptyView>
                </CollectionView>

                <Button Text="+ Add Ingredient" Clicked="OnAddIngredient"
                        BackgroundColor="{StaticResource Gray100}" TextColor="{StaticResource Primary}"
                        FontAttributes="Bold" HeightRequest="40" FontSize="13"/>
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="1" ColumnDefinitions="*, *" ColumnSpacing="12">
            <Button Text="Cancel" Clicked="OnCancelClicked"
                    BackgroundColor="{StaticResource Gray200}" TextColor="{StaticResource Gray700}"
                    FontAttributes="Bold" HeightRequest="48"/>
            <Button Grid.Column="1" Text="Save" Clicked="OnSaveClicked"
                    BackgroundColor="{StaticResource Success}" TextColor="White"
                    FontAttributes="Bold" HeightRequest="48"/>
        </Grid>
    </Grid>
</ContentPage>
