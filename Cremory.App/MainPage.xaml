<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cremory.App.Controls"
             x:Class="Cremory.App.MainPage"
             Title="Live Orders"
             BackgroundColor="{StaticResource Gray50}">

    <Grid RowDefinitions="Auto, Auto, Auto, *" Padding="20" RowSpacing="18">

        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" ColumnSpacing="16">
            <VerticalStackLayout>
                <Label Text="Kitchen View" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Gray900}"/>
                <Label Text="Active orders in the queue" FontSize="14" TextColor="{StaticResource Gray500}" Margin="0,4,0,0"/>
            </VerticalStackLayout>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*, *, *" ColumnSpacing="14">
            <Border Grid.Column="0" BackgroundColor="{StaticResource Success}" StrokeShape="RoundRectangle 12" Padding="16" Stroke="Transparent">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Revenue Today" TextColor="{StaticResource White}" FontSize="12" FontAttributes="Bold" Opacity="0.85"/>
                    <Label Text="{Binding TotalProfitToday, StringFormat='₱{0:N0}'}" TextColor="White" FontSize="24" FontAttributes="Bold"/>
                    <Label Text="{Binding CompletedOrdersText}" TextColor="White" FontSize="10" Opacity="0.75"/>
                </VerticalStackLayout>
            </Border>
            <Border Grid.Column="1" BackgroundColor="{StaticResource Info}" StrokeShape="RoundRectangle 12" Padding="16" Stroke="Transparent">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Total Orders" TextColor="White" FontSize="12" FontAttributes="Bold" Opacity="0.85"/>
                    <Label Text="{Binding TotalOrdersToday}" TextColor="White" FontSize="24" FontAttributes="Bold"/>
                    <Label Text="{Binding OrdersTotalText}" TextColor="White" FontSize="10" Opacity="0.75"/>
                </VerticalStackLayout>
            </Border>
            <Border Grid.Column="2" BackgroundColor="{StaticResource Pending}" StrokeShape="RoundRectangle 12" Padding="16" Stroke="Transparent">
                <VerticalStackLayout Spacing="6">
                    <Label Text="In Progress" TextColor="White" FontSize="12" FontAttributes="Bold" Opacity="0.85"/>
                    <Label Text="{Binding ActiveOrders.Count}" TextColor="White" FontSize="24" FontAttributes="Bold"/>
                    <Label Text="waiting for prep" TextColor="White" FontSize="10" Opacity="0.75"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Border Grid.Row="2" StrokeShape="RoundRectangle 10" BackgroundColor="White" Padding="16" StrokeThickness="1" Stroke="{StaticResource Gray200}">
            <Grid ColumnDefinitions="Auto, Auto, *" ColumnSpacing="24">
                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                    <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5" BackgroundColor="{StaticResource Success}" VerticalOptions="Center"/>
                    <Label Text="API Connected" TextColor="{StaticResource Gray700}" FontSize="12" VerticalOptions="Center" FontAttributes="Bold"/>
                </HorizontalStackLayout>
                <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                    <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5" BackgroundColor="{StaticResource Success}" VerticalOptions="Center"/>
                    <Label Text="Database Sync" TextColor="{StaticResource Gray700}" FontSize="12" VerticalOptions="Center" FontAttributes="Bold"/>
                </HorizontalStackLayout>
                <Label Grid.Column="2" x:Name="LastRefreshLabel" Text="Just now" TextColor="{StaticResource Gray500}" FontSize="11" HorizontalOptions="End" VerticalOptions="Center"/>
            </Grid>
        </Border>

        <RefreshView Grid.Row="3" x:Name="MainRefreshView" Refreshing="OnRefreshing">
            <Grid>
                <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"
                                   Color="{StaticResource Primary}" VerticalOptions="Start" HorizontalOptions="Center"
                                   Margin="0,20,0,0"/>

                <CollectionView x:Name="OrdersCollectionView" ItemsSource="{Binding ActiveOrders}">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12" Padding="0,40">
                            <Label Text="No active orders" FontSize="20" FontAttributes="Bold"
                                   TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                            <Label Text="Waiting for incoming orders..."
                                   FontSize="13" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <controls:OrderCardView Margin="0,0,0,2"/>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </RefreshView>
    </Grid>

</ContentPage>
