<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cremory.App.Controls"
             xmlns:local="clr-namespace:Cremory.App"
             xmlns:models="clr-namespace:Cremory.App.Models"
             x:Class="Cremory.App.MainPage"
             x:DataType="local:MainPage"
             Title="Live Orders"
             BackgroundColor="{StaticResource Gray50}">

    <Grid RowDefinitions="Auto, Auto, Auto, Auto, *" Padding="20" RowSpacing="14">

        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" ColumnSpacing="16">
            <VerticalStackLayout>
                <Label Text="Kitchen View" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Gray900}"/>
                <Label Text="Active orders in the queue" FontSize="14" TextColor="{StaticResource Gray500}" Margin="0,4,0,0"/>
            </VerticalStackLayout>
        </Grid>

        <ScrollView Grid.Row="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never"
                     VerticalOptions="Start">
            <HorizontalStackLayout Spacing="10" Padding="0">
                <Border BackgroundColor="{StaticResource Success}" StrokeShape="RoundRectangle 12"
                        WidthRequest="140" Padding="14,16" Stroke="Transparent">
                    <Grid RowDefinitions="Auto, Auto, Auto" RowSpacing="2" HorizontalOptions="Center">
                        <Label Grid.Row="0" Text="Revenue Today" TextColor="White" FontSize="10" FontAttributes="Bold"
                               Opacity="0.85" LineBreakMode="NoWrap" HorizontalTextAlignment="Center"/>
                        <Label Grid.Row="1" Text="{Binding TotalProfitToday, StringFormat='₱{0:N0}'}" TextColor="White"
                               FontSize="20" FontAttributes="Bold" LineBreakMode="NoWrap" HorizontalTextAlignment="Center"
                               Margin="0,2,0,0"/>
                        <Label Grid.Row="2" Text="{Binding CompletedOrdersText}" TextColor="White" FontSize="10" Opacity="0.75"
                               HorizontalTextAlignment="Center"/>
                    </Grid>
                </Border>
                <Border BackgroundColor="{StaticResource Info}" StrokeShape="RoundRectangle 12"
                        WidthRequest="140" Padding="14,16" Stroke="Transparent">
                    <Grid RowDefinitions="Auto, Auto, Auto" RowSpacing="2" HorizontalOptions="Center">
                        <Label Grid.Row="0" Text="Total Orders" TextColor="White" FontSize="10" FontAttributes="Bold"
                               Opacity="0.85" LineBreakMode="NoWrap" HorizontalTextAlignment="Center"/>
                        <Label Grid.Row="1" Text="{Binding TotalOrdersToday}" TextColor="White"
                               FontSize="20" FontAttributes="Bold" LineBreakMode="NoWrap" HorizontalTextAlignment="Center"
                               Margin="0,2,0,0"/>
                        <Label Grid.Row="2" Text="{Binding OrdersTotalText}" TextColor="White" FontSize="10" Opacity="0.75"
                               HorizontalTextAlignment="Center"/>
                    </Grid>
                </Border>
                <Border BackgroundColor="{StaticResource Pending}" StrokeShape="RoundRectangle 12"
                        WidthRequest="140" Padding="14,16" Stroke="Transparent">
                    <Grid RowDefinitions="Auto, Auto, Auto" RowSpacing="2" HorizontalOptions="Center">
                        <Label Grid.Row="0" Text="In Progress" TextColor="White" FontSize="10" FontAttributes="Bold"
                               Opacity="0.85" LineBreakMode="NoWrap" HorizontalTextAlignment="Center"/>
                        <Label Grid.Row="1" Text="{Binding ActiveOrders.Count}" TextColor="White"
                               FontSize="20" FontAttributes="Bold" LineBreakMode="NoWrap" HorizontalTextAlignment="Center"
                               Margin="0,2,0,0"/>
                        <Label Grid.Row="2" Text="waiting for prep" TextColor="White" FontSize="10" Opacity="0.75"
                               HorizontalTextAlignment="Center"/>
                    </Grid>
                </Border>
            </HorizontalStackLayout>
        </ScrollView>

        <Border x:Name="LowStockBanner" Grid.Row="2" StrokeShape="RoundRectangle 10" BackgroundColor="#FEF2F2"
                Padding="12" StrokeThickness="1" Stroke="#FECACA" IsVisible="False">
            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                <Label Text="!" FontSize="16" FontAttributes="Bold" TextColor="#991B1B"
                       VerticalOptions="Center" HorizontalOptions="Center"
                       WidthRequest="28" HeightRequest="28" BackgroundColor="#FEE2E2"
                       HorizontalTextAlignment="Center" VerticalTextAlignment="Center"/>
                <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                    <Label x:Name="LowStockTitle" FontSize="13" FontAttributes="Bold" TextColor="#991B1B"
                           Text="Low Stock Alert"/>
                    <Label x:Name="LowStockCount" FontSize="11" TextColor="#B91C1C"/>
                </VerticalStackLayout>
                <Button Grid.Column="2" Text="View" FontSize="11" HeightRequest="30" Padding="10,0"
                        BackgroundColor="#DC2626" TextColor="White" FontAttributes="Bold"
                        Clicked="OnViewLowStockClicked"/>
            </Grid>
        </Border>

        <Border Grid.Row="3" StrokeShape="RoundRectangle 10" BackgroundColor="White" Padding="16" StrokeThickness="1" Stroke="{StaticResource Gray200}">
            <Grid ColumnDefinitions="Auto, Auto, *" ColumnSpacing="24">
                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                    <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5" BackgroundColor="{StaticResource Success}" VerticalOptions="Center"/>
                    <Label Text="API Connected" TextColor="{StaticResource Gray700}" FontSize="12" VerticalOptions="Center" FontAttributes="Bold"/>
                </HorizontalStackLayout>
                <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                    <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5" BackgroundColor="{StaticResource Success}" VerticalOptions="Center"/>
                    <Label Text="Database Sync" TextColor="{StaticResource Gray700}" FontSize="12" VerticalOptions="Center" FontAttributes="Bold"/>
                </HorizontalStackLayout>
                <Label Grid.Column="2" x:Name="LastRefreshLabel" Text="Just now" TextColor="{StaticResource Gray500}" FontSize="11" HorizontalOptions="End" VerticalOptions="Center"/>
            </Grid>
        </Border>

        <RefreshView Grid.Row="4" x:Name="MainRefreshView" Refreshing="OnRefreshing">
            <Grid>
                <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"
                                   Color="{StaticResource Primary}" VerticalOptions="Start" HorizontalOptions="Center"
                                   Margin="0,20,0,0"/>

                <CollectionView x:Name="OrdersCollectionView" ItemsSource="{Binding ActiveOrders}">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12" Padding="0,40">
                            <Label Text="No active orders" FontSize="20" FontAttributes="Bold"
                                   TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                            <Label Text="Waiting for incoming orders..."
                                   FontSize="13" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:OrderSummary">
                            <controls:OrderCardView Margin="0,0,0,2"/>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </RefreshView>
    </Grid>

</ContentPage>
