<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Cremory.App.Models"
             x:Class="Cremory.App.RecipePage"
             Title="Recipes"
             BackgroundColor="{StaticResource Gray50}">

    <Grid RowDefinitions="Auto, *" Padding="20" RowSpacing="16">
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" ColumnSpacing="12">
            <VerticalStackLayout>
                <Label Text="Recipes" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Gray900}"/>
                <Label Text="Recipe costs and ingredient lists" FontSize="13" TextColor="{StaticResource Gray500}" Margin="0,4,0,0"/>
            </VerticalStackLayout>
            <Button Grid.Column="1" Text="+ Add" Clicked="OnAddClicked"
                    BackgroundColor="{StaticResource Success}" TextColor="White"
                    FontAttributes="Bold" HeightRequest="40" Padding="14,0" VerticalOptions="End"/>
        </Grid>

        <RefreshView Grid.Row="1" x:Name="RecipeRefreshView" Refreshing="OnRefreshing">
        <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False"
                           Color="{StaticResource Primary}" VerticalOptions="Center" HorizontalOptions="Center"/>

        <CollectionView x:Name="RecipesCollectionView">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                    <Label Text="No recipes yet" FontSize="20" FontAttributes="Bold"
                           TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                    <Label Text="Tap + Add to create your first recipe"
                           FontSize="13" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Recipe">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Edit" BackgroundColor="{StaticResource Info}"
                                           Invoked="OnEditSwipe"/>
                                <SwipeItem Text="Delete" BackgroundColor="{StaticResource Danger}"
                                           Invoked="OnDeleteSwipe"/>
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="1"
                                Stroke="{StaticResource Gray200}" Padding="16" Margin="0,0,0,10"
                                BackgroundColor="White">
                            <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto" RowSpacing="8">
                                <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="8">
                                    <Label Text="{Binding Name}" FontSize="17" FontAttributes="Bold"
                                           TextColor="{StaticResource Gray900}"/>
                                    <Border StrokeShape="RoundRectangle 6" Padding="6,2"
                                            BackgroundColor="{StaticResource Success}"
                                            Stroke="Transparent"
                                            IsVisible="{Binding IsActive}">
                                        <Label Text="Active" FontSize="9" FontAttributes="Bold"
                                               TextColor="White"/>
                                    </Border>
                                </HorizontalStackLayout>
                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="{Binding SellingPrice, StringFormat='₱{0:N0}'}"
                                       FontSize="20" FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}" HorizontalOptions="End"/>
                                <Label Grid.Row="1" Grid.ColumnSpan="2"
                                       Text="{Binding Description}"
                                       FontSize="12" TextColor="{StaticResource Gray500}"
                                       LineBreakMode="TailTruncation" MaxLines="2"/>
                                <Label Grid.Row="2" Grid.ColumnSpan="2"
                                       FontSize="11" TextColor="{StaticResource Gray400}">
                                    <Label.Text>
                                        <MultiBinding StringFormat="{}{0} ingredient(s)">
                                            <Binding Path="RecipeIngredients.Count"/>
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        </RefreshView>
    </Grid>

</ContentPage>
