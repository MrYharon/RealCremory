<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Cremory.App.Models"
             x:Class="Cremory.App.AnalyticsPage"
             Title="Analytics"
             BackgroundColor="{StaticResource Gray50}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <VerticalStackLayout Spacing="6">
                <Label Text="Analytics" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Gray900}"/>
                <Label Text="Sales numbers and product performance" FontSize="13" TextColor="{StaticResource Gray500}"/>
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                <Border StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="16"
                        Stroke="{StaticResource Gray200}">
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Label Text="Popular Items" FontSize="14" FontAttributes="Bold"
                               TextColor="{StaticResource Gray900}" HorizontalTextAlignment="Center"/>
                        <BoxView HeightRequest="1" Color="{StaticResource Gray100}"/>
                        <CollectionView x:Name="PopularItemsCollection" HeightRequest="200">
                            <CollectionView.EmptyView>
                                <Label Text="No sales data yet" FontSize="12" TextColor="{StaticResource Gray400}"
                                       HorizontalTextAlignment="Center" Padding="0,20"/>
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:PopularItemDto">
                                    <Grid Padding="0,4" ColumnDefinitions="*, Auto">
                                        <Label Text="{Binding Name}" FontSize="12"
                                               TextColor="{StaticResource Gray700}"/>
                                        <Label Grid.Column="1" Text="{Binding Count, StringFormat='{0} sold'}"
                                               FontSize="12" FontAttributes="Bold"
                                               TextColor="{StaticResource Primary}" HorizontalOptions="End"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="16"
                        Stroke="{StaticResource Gray200}">
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Label Text="Order Sources" FontSize="14" FontAttributes="Bold"
                               TextColor="{StaticResource Gray900}" HorizontalTextAlignment="Center"/>
                        <BoxView HeightRequest="1" Color="{StaticResource Gray100}"/>
                        <Grid RowDefinitions="Auto, Auto" RowSpacing="14" ColumnDefinitions="*, Auto">
                            <Label Grid.Row="0" Grid.Column="0" Text="Facebook Orders" FontSize="12"
                                   TextColor="{StaticResource Gray700}"/>
                            <Label x:Name="FbPctLabel" Grid.Row="0" Grid.Column="1" Text="0%" FontSize="14"
                                   FontAttributes="Bold" TextColor="{StaticResource Info}" HorizontalOptions="End"/>
                            <Label Grid.Row="1" Grid.Column="0" Text="Walk-in Orders" FontSize="12"
                                   TextColor="{StaticResource Gray700}"/>
                            <Label x:Name="WalkInPctLabel" Grid.Row="1" Grid.Column="1" Text="0%" FontSize="14"
                                   FontAttributes="Bold" TextColor="{StaticResource Success}" HorizontalOptions="End"/>
                        </Grid>
                        <VerticalStackLayout Spacing="8" Margin="0,12,0,0">
                            <ProgressBar x:Name="FbProgress" Progress="0" ProgressColor="{StaticResource Info}"
                                         HeightRequest="8"/>
                            <ProgressBar x:Name="WalkInProgress" Progress="0" ProgressColor="{StaticResource Success}"
                                         HeightRequest="8"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="16"
                    Stroke="{StaticResource Gray200}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Weekly Sales Trend" FontSize="16" FontAttributes="Bold"
                           TextColor="{StaticResource Gray900}"/>
                    <BoxView HeightRequest="1" Color="{StaticResource Gray100}"/>
                    <Grid x:Name="WeeklyChartGrid" ColumnDefinitions="*, *, *, *, *, *, *"
                          RowDefinitions="Auto, Auto" RowSpacing="8" ColumnSpacing="6" HeightRequest="120"/>
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                <Border StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource Warning}"
                        Padding="16" Stroke="Transparent">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Low Stock Alerts" FontSize="12" TextColor="White" Opacity="0.85"/>
                        <Label x:Name="LowStockLabel" Text="0" FontSize="36" FontAttributes="Bold" TextColor="White"/>
                        <Label Text="ingredients need reorder" FontSize="11" TextColor="White" Opacity="0.75"/>
                    </VerticalStackLayout>
                </Border>
                <Border StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource Success}"
                        Padding="16" Stroke="Transparent">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Avg Order Value" FontSize="12" TextColor="White" Opacity="0.85"/>
                        <Label x:Name="AvgOrderValueLabel" Text="₱0" FontSize="36" FontAttributes="Bold" TextColor="White"/>
                        <Label Text="per transaction" FontSize="11" TextColor="White" Opacity="0.75"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>
            <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False"
                               Color="{StaticResource Primary}" VerticalOptions="Center" HorizontalOptions="Center"
                               Margin="0,40"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
