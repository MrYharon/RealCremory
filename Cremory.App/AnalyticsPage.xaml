<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Cremory.App.Models"
             x:Class="Cremory.App.AnalyticsPage"
             Title="Analytics"
             BackgroundColor="{StaticResource Gray50}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <VerticalStackLayout Spacing="6">
                <Label Text="Analytics" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Gray900}"/>
                <Label Text="Revenue, sales, and business performance" FontSize="13" TextColor="{StaticResource Gray500}"/>
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto"
                  ColumnSpacing="12" RowSpacing="12">
                <Border Grid.Row="0" Grid.Column="0" StrokeShape="RoundRectangle 12"
                        BackgroundColor="White" Padding="16" Stroke="{StaticResource Gray200}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Today's Revenue" FontSize="12" TextColor="{StaticResource Gray500}"/>
                        <Label x:Name="TodayRevenue" Text="--" FontSize="26" FontAttributes="Bold"
                               TextColor="{StaticResource Success}"/>
                        <Label x:Name="TodayOrdersLabel" Text="" FontSize="11" TextColor="{StaticResource Gray500}"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" StrokeShape="RoundRectangle 12"
                        BackgroundColor="White" Padding="16" Stroke="{StaticResource Gray200}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="This Week" FontSize="12" TextColor="{StaticResource Gray500}"/>
                        <Label x:Name="WeekRevenue" Text="--" FontSize="26" FontAttributes="Bold"
                               TextColor="{StaticResource Gray900}"/>
                        <Label x:Name="WeekAverageLabel" Text="" FontSize="11" TextColor="{StaticResource Gray500}"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" StrokeShape="RoundRectangle 12"
                        BackgroundColor="White" Padding="16" Stroke="{StaticResource Gray200}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="This Month" FontSize="12" TextColor="{StaticResource Gray500}"/>
                        <Label x:Name="MonthRevenue" Text="--" FontSize="26" FontAttributes="Bold"
                               TextColor="{StaticResource Gray900}"/>
                        <Label x:Name="MonthOrdersLabel" Text="" FontSize="11" TextColor="{StaticResource Gray500}"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" StrokeShape="RoundRectangle 12"
                        BackgroundColor="White" Padding="16" Stroke="{StaticResource Gray200}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Avg Order Value" FontSize="12" TextColor="{StaticResource Gray500}"/>
                        <Label x:Name="AvgOrderLabel" Text="--" FontSize="26" FontAttributes="Bold"
                               TextColor="{StaticResource Primary}"/>
                        <Label Text="This month" FontSize="11" TextColor="{StaticResource Gray500}"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="16"
                    Stroke="{StaticResource Gray200}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Recent Transactions" FontSize="16" FontAttributes="Bold"
                           TextColor="{StaticResource Gray900}"/>
                    <BoxView HeightRequest="1" Color="{StaticResource Gray100}"/>
                    <CollectionView x:Name="TransactionsCollection" HeightRequest="200">
                        <CollectionView.EmptyView>
                            <Label Text="No recent transactions" FontSize="13" TextColor="{StaticResource Gray400}"
                                   HorizontalTextAlignment="Center" Padding="0,20"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:RecentTransactionDto">
                                <Grid ColumnDefinitions="*, Auto, Auto" Padding="0,6" ColumnSpacing="12">
                                    <Label Text="{Binding CustomerName}" FontSize="13"
                                           TextColor="{StaticResource Gray800}"/>
                                    <Label Grid.Column="1" Text="{Binding TotalPrice, StringFormat='₱{0:N0}'}"
                                           FontSize="13" FontAttributes="Bold"
                                           TextColor="{StaticResource Success}" HorizontalOptions="End"/>
                                    <Label Grid.Column="2" Text="{Binding Timestamp}" FontSize="11"
                                           TextColor="{StaticResource Gray400}" VerticalOptions="Center"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                <Border StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="16"
                        Stroke="{StaticResource Gray200}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Popular Items" FontSize="14" FontAttributes="Bold"
                               TextColor="{StaticResource Gray900}"/>
                        <BoxView HeightRequest="1" Color="{StaticResource Gray100}"/>
                        <CollectionView x:Name="PopularItemsCollection" HeightRequest="180">
                            <CollectionView.EmptyView>
                                <Label Text="No sales data yet" FontSize="12" TextColor="{StaticResource Gray400}"
                                       HorizontalTextAlignment="Center" Padding="0,20"/>
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:PopularItemDto">
                                    <Grid Padding="0,4" ColumnDefinitions="*, Auto">
                                        <Label Text="{Binding Name}" FontSize="12"
                                               TextColor="{StaticResource Gray700}"/>
                                        <Label Grid.Column="1" Text="{Binding Count, StringFormat='{0} sold'}"
                                               FontSize="12" FontAttributes="Bold"
                                               TextColor="{StaticResource Primary}" HorizontalOptions="End"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="16"
                        Stroke="{StaticResource Gray200}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Order Sources" FontSize="14" FontAttributes="Bold"
                               TextColor="{StaticResource Gray900}"/>
                        <BoxView HeightRequest="1" Color="{StaticResource Gray100}"/>
                        <Grid RowDefinitions="Auto, Auto" RowSpacing="14" ColumnDefinitions="*, Auto" Margin="0,8,0,0">
                            <Label Grid.Row="0" Grid.Column="0" Text="Facebook" FontSize="12"
                                   TextColor="{StaticResource Gray700}"/>
                            <Label x:Name="FbPctLabel" Grid.Row="0" Grid.Column="1" Text="--" FontSize="14"
                                   FontAttributes="Bold" TextColor="{StaticResource Info}" HorizontalOptions="End"/>
                            <Label Grid.Row="1" Grid.Column="0" Text="Walk-in" FontSize="12"
                                   TextColor="{StaticResource Gray700}"/>
                            <Label x:Name="WalkInPctLabel" Grid.Row="1" Grid.Column="1" Text="--" FontSize="14"
                                   FontAttributes="Bold" TextColor="{StaticResource Success}" HorizontalOptions="End"/>
                        </Grid>
                        <VerticalStackLayout Spacing="8" Margin="0,4,0,0">
                            <ProgressBar x:Name="FbProgress" Progress="0" ProgressColor="{StaticResource Info}"
                                         HeightRequest="6"/>
                            <ProgressBar x:Name="WalkInProgress" Progress="0" ProgressColor="{StaticResource Success}"
                                         HeightRequest="6"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="16"
                    Stroke="{StaticResource Gray200}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Weekly Sales Trend" FontSize="16" FontAttributes="Bold"
                           TextColor="{StaticResource Gray900}"/>
                    <BoxView HeightRequest="1" Color="{StaticResource Gray100}"/>
                    <Grid x:Name="WeeklyChartGrid" ColumnDefinitions="*, *, *, *, *, *, *"
                          RowDefinitions="Auto, Auto" RowSpacing="8" ColumnSpacing="6" HeightRequest="120"/>
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                <Border StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource Primary}"
                        Padding="16" Stroke="Transparent">
                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Profit Margin" FontSize="12" TextColor="White" Opacity="0.85"/>
                            <Label x:Name="ProfitMarginLabel" Text="--" FontSize="30" FontAttributes="Bold" TextColor="White"/>
                            <Label Text="Estimated this month" FontSize="10" TextColor="White" Opacity="0.75"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4" HorizontalOptions="End">
                            <Label Text="Net Profit" FontSize="11" TextColor="White" Opacity="0.85"/>
                            <Label x:Name="NetProfitLabel" Text="--" FontSize="18" FontAttributes="Bold" TextColor="White"
                                   HorizontalOptions="End"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>
                <Border StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource Warning}"
                        Padding="16" Stroke="Transparent">
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="Low Stock Alerts" FontSize="12" TextColor="White" Opacity="0.85"
                               HorizontalTextAlignment="Center"/>
                        <Label x:Name="LowStockLabel" Text="--" FontSize="30" FontAttributes="Bold" TextColor="White"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="ingredients need reorder" FontSize="10" TextColor="White" Opacity="0.75"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False"
                               Color="{StaticResource Primary}" VerticalOptions="Center" HorizontalOptions="Center"
                               Margin="0,20"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
