<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Pastel Pink & Red Theme — Premium Bakery Boutique -->

    <!-- Brand Colors -->
    <Color x:Key="Primary">#FBC4C4</Color>
    <Color x:Key="PrimaryDark">#E27575</Color>
    <Color x:Key="PrimaryLight">#FDE8E8</Color>
    <Color x:Key="PrimaryVeryLight">#FEF2F2</Color>

    <!-- Accent Colors -->
    <Color x:Key="PastelMint">#C4FBD5</Color>
    <Color x:Key="SecondaryText">#554B4B</Color>
    <Color x:Key="Success">#81B29A</Color>
    <Color x:Key="SuccessLight">#D4E8D8</Color>
    <Color x:Key="Warning">#E07A5F</Color>
    <Color x:Key="WarningLight">#F4D4C8</Color>
    <Color x:Key="Danger">#E27575</Color>
    <Color x:Key="DangerLight">#F5D0D0</Color>
    <Color x:Key="Info">#A08B9E</Color>
    <Color x:Key="InfoLight">#E8DEE7</Color>
    <Color x:Key="Pending">#FBC4C4</Color>
    <Color x:Key="PendingLight">#FDE8E8</Color>

    <!-- Neutral Colors -->
    <Color x:Key="White">#FFFDFD</Color>
    <Color x:Key="Black">#2C2525</Color>
    <Color x:Key="OffBlack">#3D3333</Color>
    <Color x:Key="Surface">#FFFDFD</Color>

    <!-- Warm Gray Scale -->
    <Color x:Key="Gray50">#FFFDFD</Color>
    <Color x:Key="Gray100">#FDF5F5</Color>
    <Color x:Key="Gray200">#F5E8E8</Color>
    <Color x:Key="Gray300">#E8D4D4</Color>
    <Color x:Key="Gray400">#D4B8B8</Color>
    <Color x:Key="Gray500">#B89292</Color>
    <Color x:Key="Gray600">#9C7575</Color>
    <Color x:Key="Gray700">#7D5A5A</Color>
    <Color x:Key="Gray800">#5C4444</Color>
    <Color x:Key="Gray900">#3D3333</Color>
    <Color x:Key="Gray950">#2C2525</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDark}"/>
    <SolidColorBrush x:Key="PastelMintBrush" Color="{StaticResource PastelMint}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="SuccessLightBrush" Color="{StaticResource SuccessLight}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource Info}"/>

    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}"/>
    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray700Brush" Color="{StaticResource Gray700}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
</ResourceDictionary>