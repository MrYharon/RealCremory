<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Cremory.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Cremory.App"
    Shell.FlyoutBehavior="Flyout"
    Title="Cremory">

    <Shell.FlyoutHeader>
        <Grid HeightRequest="160" BackgroundColor="#512BD4" Padding="20">
            <VerticalStackLayout VerticalOptions="End">
                <Label Text="Cremory App" TextColor="White" FontSize="24" FontAttributes="Bold"/>
                <Label Text="Admin Dashboard" TextColor="#D1C4E9" FontSize="14"/>
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <FlyoutItem Title="🏠 Main Dashboard">
        <ShellContent ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage" />
    </FlyoutItem>

    <FlyoutItem Title="🍳 Orders Queue">
        <ShellContent ContentTemplate="{DataTemplate local:OrdersPage}" Route="OrdersPage" />
    </FlyoutItem>

    <FlyoutItem Title="📦 Live Inventory">
        <ShellContent ContentTemplate="{DataTemplate local:InventoryPage}" Route="InventoryPage" />
    </FlyoutItem>

    <FlyoutItem Title="📈 Analytics &amp; Finances">
        <ShellContent ContentTemplate="{DataTemplate local:AnalyticsPage}" Route="AnalyticsPage" />
    </FlyoutItem>

</Shell>