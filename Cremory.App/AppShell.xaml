<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Cremory.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Cremory.App"
    Shell.FlyoutBehavior="Flyout"
    Shell.FlyoutBackgroundColor="#FFFDFD"
    Title="Cremory">

    <Shell.FlyoutHeader>
        <Grid HeightRequest="160" BackgroundColor="#C97586" Padding="20">
            <VerticalStackLayout VerticalOptions="End" Spacing="4">
                <Label Text="The Cremory" TextColor="White" FontSize="28" FontAttributes="Bold" FontFamily="OpenSansSemibold"/>
                <Label Text="Bakery POS" TextColor="#FCE4EC" FontSize="14"/>
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid Padding="20,12" ColumnSpacing="12" ColumnDefinitions="Auto, *">
                <Label Text="{Binding Title}"
                       FontSize="15" FontAttributes="Bold"
                       TextColor="#2C2525" VerticalOptions="Center"
                       Grid.Column="1"/>
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>

    <FlyoutItem Title="Dashboard">
        <ShellContent ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage" />
    </FlyoutItem>

    <FlyoutItem Title="Orders">
        <ShellContent ContentTemplate="{DataTemplate local:OrdersPage}" Route="OrdersPage" />
    </FlyoutItem>

    <FlyoutItem Title="Products">
        <ShellContent ContentTemplate="{DataTemplate local:ProductPage}" Route="ProductPage" />
    </FlyoutItem>

    <FlyoutItem Title="Recipes">
        <ShellContent ContentTemplate="{DataTemplate local:RecipePage}" Route="RecipePage" />
    </FlyoutItem>

    <FlyoutItem Title="Inventory">
        <ShellContent ContentTemplate="{DataTemplate local:InventoryPage}" Route="InventoryPage" />
    </FlyoutItem>

    <FlyoutItem Title="Analytics">
        <ShellContent ContentTemplate="{DataTemplate local:AnalyticsPage}" Route="AnalyticsPage" />
    </FlyoutItem>

    <FlyoutItem Title="Settings">
        <ShellContent ContentTemplate="{DataTemplate local:SettingsPage}" Route="SettingsPage" />
    </FlyoutItem>

</Shell>
