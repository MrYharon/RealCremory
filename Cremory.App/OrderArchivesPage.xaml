<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Cremory.App.Models"
             x:Class="Cremory.App.OrderArchivesPage"
             Title="Order History"
             BackgroundColor="{StaticResource Gray50}">

    <Grid RowDefinitions="Auto, Auto, *" Padding="20" RowSpacing="16">
        <VerticalStackLayout Grid.Row="0" Spacing="6">
            <Label Text="Order History" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Gray900}"/>
            <Label Text="View completed and archived orders" FontSize="13" TextColor="{StaticResource Gray500}"/>
        </VerticalStackLayout>

        <Border Grid.Row="1" StrokeShape="RoundRectangle 10" BackgroundColor="White"
                Padding="12" StrokeThickness="1" Stroke="{StaticResource Gray200}">
            <Grid ColumnDefinitions="*, *, Auto" ColumnSpacing="10">
                <Picker x:Name="DateRangePicker" SelectedIndexChanged="OnFilterChanged" Title="Date Range" TextColor="{StaticResource Gray900}"
                        TitleColor="{StaticResource Gray500}" BackgroundColor="{StaticResource Gray50}">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>Today</x:String>
                            <x:String>This Week</x:String>
                            <x:String>This Month</x:String>
                            <x:String>All Time</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
                <Picker x:Name="StatusPicker" SelectedIndexChanged="OnFilterChanged" Title="Status" TextColor="{StaticResource Gray900}"
                        TitleColor="{StaticResource Gray500}" BackgroundColor="{StaticResource Gray50}">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>All</x:String>
                            <x:String>Completed</x:String>
                            <x:String>Cancelled</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
                <Button Grid.Column="2" Text="Filter" Clicked="OnFilterClicked"
                        BackgroundColor="{StaticResource Primary}" TextColor="White"
                        HeightRequest="40" Padding="16,0" VerticalOptions="Center"/>
            </Grid>
        </Border>

        <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False"
                           Color="{StaticResource Primary}" VerticalOptions="Center" HorizontalOptions="Center"
                           Grid.Row="2"/>
        <CollectionView Grid.Row="2" x:Name="ArchivesCollectionView">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                    <Label Text="No archived orders" FontSize="20" FontAttributes="Bold"
                           TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                    <Label Text="Completed orders will appear here"
                           FontSize="13" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:OrderSummary">
                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="1"
                            Stroke="{StaticResource Gray200}" Padding="16" Margin="0,0,0,10"
                            BackgroundColor="White">
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto" RowSpacing="8">
                            <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="12">
                                <BoxView WidthRequest="40" HeightRequest="40" CornerRadius="20"
                                         BackgroundColor="{StaticResource Gray300}"/>
                                <VerticalStackLayout VerticalOptions="Center">
                                    <Label Text="{Binding CustomerName}" FontSize="15" FontAttributes="Bold"
                                           TextColor="{StaticResource Gray900}"/>
                                    <Label Text="{Binding Timestamp}" FontSize="11" TextColor="{StaticResource Gray500}"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                            <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="4"
                                                VerticalOptions="Center" HorizontalOptions="End">
                                <Label Text="{Binding OrderId}" FontSize="11" FontAttributes="Bold"
                                       TextColor="{StaticResource Gray500}" HorizontalOptions="End"/>
                                <Label Text="{Binding StatusBadge}" FontSize="9" FontAttributes="Bold"
                                       TextColor="White"
                                       BackgroundColor="{Binding StatusColor}" Padding="8,4" HorizontalOptions="End"/>
                            </VerticalStackLayout>
                            <Border Grid.Row="1" Grid.ColumnSpan="2" BackgroundColor="{StaticResource Gray50}"
                                    Stroke="Transparent" Padding="12" StrokeShape="RoundRectangle 8">
                                <Label Text="{Binding Items}" FontSize="12" TextColor="{StaticResource Gray600}"
                                       LineBreakMode="WordWrap"/>
                            </Border>
                            <Label Grid.Row="2" Grid.Column="0"
                                   Text="{Binding TotalPrice, StringFormat='Total: ₱{0:N2}'}"
                                   FontSize="14" FontAttributes="Bold" TextColor="{StaticResource Gray800}"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
