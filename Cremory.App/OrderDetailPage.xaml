<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Cremory.App"
             xmlns:models="clr-namespace:Cremory.App.Models"
             x:Class="Cremory.App.OrderDetailPage"
             x:DataType="local:OrderDetailPage"
             Title="Order Details"
             BackgroundColor="{StaticResource Gray50}">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="16">

            <Border StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="20"
                    Stroke="{StaticResource Gray200}">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Order.CustomerName}" FontSize="22" FontAttributes="Bold"
                                   TextColor="{StaticResource Gray900}"/>
                            <Label Text="{Binding Order.OrderId, StringFormat='Order #{0}'}" FontSize="13"
                                   TextColor="{StaticResource Gray500}"/>
                        </VerticalStackLayout>
                        <Border Grid.Column="1" StrokeShape="RoundRectangle 6" Padding="12,6"
                                BackgroundColor="{Binding Order.StatusColor}" Stroke="Transparent"
                                VerticalOptions="Center">
                            <Label Text="{Binding Order.StatusBadge}" FontSize="11" FontAttributes="Bold"
                                   TextColor="White"/>
                        </Border>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource Gray100}"/>

                    <Grid ColumnDefinitions="Auto, *" RowSpacing="10" ColumnSpacing="16">
                        <Label Text="Source" FontSize="13" TextColor="{StaticResource Gray500}"/>
                        <Label Grid.Column="1" Text="{Binding Order.Source}" FontSize="14"
                               TextColor="{StaticResource Gray800}" FontAttributes="Bold"/>

                        <Label Grid.Row="1" Text="Contact" FontSize="13" TextColor="{StaticResource Gray500}"/>
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding Order.CustomerContact}"
                               FontSize="14" TextColor="{StaticResource Gray800}"
                               IsVisible="{Binding HasContact}"/>

                        <Label Grid.Row="2" Text="Created" FontSize="13" TextColor="{StaticResource Gray500}"/>
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding CreatedAt}" FontSize="14"
                               TextColor="{StaticResource Gray800}"/>

                        <Label Grid.Row="3" Text="Updated" FontSize="13" TextColor="{StaticResource Gray500}"/>
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding UpdatedAt}" FontSize="14"
                               TextColor="{StaticResource Gray800}"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="20"
                    Stroke="{StaticResource Gray200}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Items" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource Gray900}"/>
                    <BoxView HeightRequest="1" Color="{StaticResource Gray100}"/>
                    <Border BackgroundColor="{StaticResource Gray50}" Stroke="Transparent"
                            Padding="14" StrokeShape="RoundRectangle 8">
                        <Label Text="{Binding Order.Items}" FontSize="14" TextColor="{StaticResource Gray800}"
                               LineBreakMode="WordWrap"/>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource Primary}"
                    Padding="20" Stroke="Transparent">
                <Grid ColumnDefinitions="*, Auto">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Total Price" FontSize="13" TextColor="White" Opacity="0.85"/>
                        <Label Text="{Binding Order.TotalPrice, StringFormat='₱{0:N2}'}" FontSize="32"
                               FontAttributes="Bold" TextColor="White"/>
                    </VerticalStackLayout>
                    <Label Grid.Column="1" Text="{Binding Order.StatusMessage}" FontSize="11"
                           TextColor="White" Opacity="0.75" VerticalOptions="End"/>
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                <Button x:Name="ActionButton" Text="{Binding Order.ActionButtonText}"
                        Clicked="OnActionClicked"
                        BackgroundColor="{Binding Order.ActionButtonColor}"
                        TextColor="White" FontAttributes="Bold" HeightRequest="48"
                        IsVisible="{Binding Order.ShowActionButton}"/>
                <Button Grid.Column="1" Text="Back" Clicked="OnBackClicked"
                        BackgroundColor="{StaticResource Gray200}" TextColor="{StaticResource Gray700}"
                        FontAttributes="Bold" HeightRequest="48"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
