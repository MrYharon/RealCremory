<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Cremory.App.Models"
             x:DataType="models:OrderSummary"
             x:Class="Cremory.App.Controls.OrderCardView">

    <SwipeView>
        <SwipeView.LeftItems>
            <SwipeItems>
                <SwipeItem Text="Edit" BackgroundColor="{StaticResource Info}"
                           Invoked="OnEditSwipe"/>
            </SwipeItems>
        </SwipeView.LeftItems>
        <SwipeView.RightItems>
            <SwipeItems>
                <SwipeItem Text="Cancel" BackgroundColor="{StaticResource Danger}"
                           Invoked="OnCancelSwipe"/>
                <SwipeItem Text="Delete" BackgroundColor="#C62828"
                           Invoked="OnDeleteSwipe"/>
            </SwipeItems>
        </SwipeView.RightItems>

        <Border x:Name="CardBorder" StrokeShape="RoundRectangle 12" StrokeThickness="1.5"
                Stroke="{Binding BorderColor}" BackgroundColor="White" Padding="14" Margin="0,0,0,8">
            <Grid RowSpacing="8">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer NumberOfTapsRequired="2" Tapped="OnCardDoubleTapped"/>
                </Grid.GestureRecognizers>

                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="{Binding CustomerName}" FontSize="15" FontAttributes="Bold"
                           TextColor="{StaticResource Gray900}" LineBreakMode="TailTruncation" MaxLines="1"/>
                    <Border Grid.Column="1" StrokeShape="RoundRectangle 6" Padding="8,3"
                            BackgroundColor="{Binding StatusColor}" Stroke="Transparent"
                            VerticalOptions="Center">
                        <Label Text="{Binding StatusBadge}" FontSize="9" FontAttributes="Bold"
                               TextColor="White"/>
                    </Border>
                </Grid>

                <Label Grid.Row="1" Text="{Binding Timestamp}" FontSize="11"
                       TextColor="{StaticResource Gray500}" Opacity="0.6"/>

                <Border Grid.Row="2" BackgroundColor="{StaticResource Gray50}"
                        Stroke="Transparent" Padding="10" StrokeShape="RoundRectangle 8">
                    <Label Text="{Binding Items}" FontSize="12" TextColor="{StaticResource Gray600}"
                           LineBreakMode="TailTruncation" MaxLines="2"/>
                </Border>

                <Grid Grid.Row="3" ColumnDefinitions="Auto, *">
                    <Label Text="{Binding TotalPrice, StringFormat='₱{0:N2}'}"
                           FontSize="17" FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryDark}" VerticalOptions="Center"/>
                    <Button Grid.Column="1" Text="{Binding ActionButtonText}"
                            Clicked="OnActionClicked"
                            BackgroundColor="{Binding ActionButtonColor}" TextColor="White"
                            HeightRequest="34" Padding="14,0" FontAttributes="Bold" FontSize="11"
                            CornerRadius="8" IsVisible="{Binding ShowActionButton}"
                            HorizontalOptions="End"/>
                </Grid>
            </Grid>
        </Border>
    </SwipeView>

</ContentView>
