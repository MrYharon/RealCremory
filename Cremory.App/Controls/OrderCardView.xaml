<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Cremory.App.Models"
             x:DataType="models:OrderSummary"
             x:Class="Cremory.App.Controls.OrderCardView">

    <SwipeView>
        <SwipeView.RightItems>
            <SwipeItems>
                <SwipeItem Text="Cancel" BackgroundColor="{StaticResource Danger}"
                           Invoked="OnCancelSwipe"/>
            </SwipeItems>
        </SwipeView.RightItems>
        <Border StrokeShape="RoundRectangle 12" StrokeThickness="1"
                Stroke="{Binding BorderColor}" Padding="16" Margin="0,0,0,10"
                BackgroundColor="White">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCardTapped"/>
            </Border.GestureRecognizers>
            <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto, Auto" RowSpacing="10">
                <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="12" VerticalOptions="Center">
                    <BoxView WidthRequest="44" HeightRequest="44" CornerRadius="22"
                             BackgroundColor="{Binding AvatarColor}"/>
                    <VerticalStackLayout VerticalOptions="Center">
                        <Label Text="{Binding CustomerName}" FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource Gray900}"/>
                        <Label Text="{Binding Timestamp}" FontSize="12" TextColor="{StaticResource Gray500}"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
                <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="4"
                                     VerticalOptions="Center" HorizontalOptions="End">
                    <Label Text="{Binding OrderId}" FontSize="12" FontAttributes="Bold"
                           TextColor="{StaticResource Primary}" HorizontalOptions="End"/>
                    <Label Text="{Binding StatusBadge}" FontSize="10" FontAttributes="Bold" TextColor="White"
                           BackgroundColor="{Binding StatusColor}" Padding="10,5" HorizontalOptions="End"/>
                </VerticalStackLayout>
                <Border Grid.Row="1" Grid.ColumnSpan="2" BackgroundColor="{StaticResource Gray50}"
                        Stroke="Transparent" Padding="12" StrokeShape="RoundRectangle 8">
                    <Label Text="{Binding Items}" FontSize="13" TextColor="{StaticResource Gray700}"
                           LineBreakMode="WordWrap"/>
                </Border>
                <Label Grid.Row="2" Grid.Column="0"
                       Text="{Binding TotalPrice, StringFormat='Total: ₱{0:N2}'}"
                       FontSize="15" FontAttributes="Bold" TextColor="{StaticResource Gray900}"
                       VerticalOptions="Center"/>
                <Button Grid.Row="2" Grid.Column="1" Text="{Binding ActionButtonText}"
                        Clicked="OnActionClicked"
                        BackgroundColor="{Binding ActionButtonColor}" TextColor="White"
                        HeightRequest="38" Padding="14,0" FontAttributes="Bold" FontSize="12"
                        IsVisible="{Binding ShowActionButton}"/>
                <Label Grid.Row="3" Grid.ColumnSpan="2" Text="{Binding StatusMessage}"
                       FontSize="11" TextColor="{StaticResource Gray500}" Margin="0,2,0,0"/>
            </Grid>
        </Border>
    </SwipeView>

</ContentView>
