<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Cremory.App.Models"
             x:DataType="models:OrderSummary"
             x:Class="Cremory.App.Controls.OrderCardView">

    <Border x:Name="CardBorder"
            StrokeShape="RoundRectangle 16"
            Stroke="{Binding BorderColor}" StrokeThickness="1.5"
            BackgroundColor="White" Padding="20" Margin="0,0,0,14"
            MinimumHeightRequest="150"
            Shadow="{OnPlatform Default={Shadow Brush=Black, Offset='0,2', Radius=12, Opacity=0.06}}">
        <Border.GestureRecognizers>
            <TapGestureRecognizer NumberOfTapsRequired="2" Tapped="OnCardDoubleTapped"/>
        </Border.GestureRecognizers>

        <Grid RowDefinitions="Auto, Auto, Auto" RowSpacing="14">

            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                <Label Text="{Binding CustomerName}"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="#2C2525"
                       LineBreakMode="TailTruncation" MaxLines="1"/>
                <Label Grid.Column="1" Text="{Binding Timestamp}"
                       FontSize="11" TextColor="#B89292"
                       VerticalOptions="Center"/>
            </Grid>

            <Border Grid.Row="1"
                    StrokeShape="RoundRectangle 10"
                    BackgroundColor="#FDF5F5" Stroke="Transparent"
                    Padding="14,12">
                <Label Text="{Binding Items}"
                       FontSize="14" TextColor="#7D5A5A"
                       LineBreakMode="WordWrap" MaxLines="4"/>
            </Border>

            <Grid Grid.Row="2" ColumnDefinitions="Auto, *, Auto, Auto" ColumnSpacing="8">
                <Label Text="{Binding TotalPrice, StringFormat='₱{0:N2}'}"
                       FontSize="24" FontAttributes="Bold"
                       TextColor="#E27575" VerticalOptions="Center"/>
                <Button Grid.Column="2" Text="⋮"
                        BackgroundColor="Transparent" TextColor="#B89292"
                        FontSize="20" FontAttributes="Bold"
                        WidthRequest="36" HeightRequest="36"
                        Padding="0" CornerRadius="18"
                        Clicked="OnMoreClicked"/>
                <Button x:Name="ActionBtn" Grid.Column="3" Text="{Binding ActionButtonText}"
                        Clicked="OnActionClicked"
                        BackgroundColor="{Binding ActionButtonColor}"
                        TextColor="White"
                        HeightRequest="40" Padding="18,0"
                        FontAttributes="Bold" FontSize="12"
                        CornerRadius="10"
                        IsVisible="{Binding ShowActionButton}"/>
            </Grid>
        </Grid>
    </Border>
</ContentView>
