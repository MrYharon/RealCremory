<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Cremory.App.Models"
             x:DataType="models:OrderSummary"
             x:Class="Cremory.App.Controls.OrderCardView">

    <SwipeView>
        <SwipeView.LeftItems>
            <SwipeItems>
                <SwipeItem Text="Edit" BackgroundColor="{StaticResource Info}"
                           Invoked="OnEditSwipe"/>
            </SwipeItems>
        </SwipeView.LeftItems>
        <SwipeView.RightItems>
            <SwipeItems>
                <SwipeItem Text="Cancel" BackgroundColor="{StaticResource Danger}"
                           Invoked="OnCancelSwipe"/>
                <SwipeItem Text="Delete" BackgroundColor="#C62828"
                           Invoked="OnDeleteSwipe"/>
            </SwipeItems>
        </SwipeView.RightItems>

        <Border x:Name="CardBorder"
                StrokeShape="RoundRectangle 14"
                Stroke="{Binding BorderColor}" StrokeThickness="1"
                BackgroundColor="White" Padding="16" Margin="0,0,0,10">
            <Grid RowSpacing="10">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer NumberOfTapsRequired="2" Tapped="OnCardDoubleTapped"/>
                </Grid.GestureRecognizers>

                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="{Binding CustomerName}"
                           FontSize="17" FontAttributes="Bold"
                           TextColor="#2C2525"
                           LineBreakMode="TailTruncation" MaxLines="1"/>
                    <Label Grid.Column="1" Text="{Binding Timestamp}"
                           FontSize="11" TextColor="#B89292"
                           VerticalOptions="Center"/>
                </Grid>

                <Border Grid.Row="1"
                        StrokeShape="RoundRectangle 8"
                        BackgroundColor="#FDF5F5" Stroke="Transparent"
                        Padding="10">
                    <Label Text="{Binding Items}"
                           FontSize="13" TextColor="#7D5A5A"
                           LineBreakMode="TailTruncation" MaxLines="2"/>
                </Border>

                <Grid Grid.Row="2" ColumnDefinitions="Auto, *">
                    <Label Text="{Binding TotalPrice, StringFormat='₱{0:N2}'}"
                           FontSize="17" FontAttributes="Bold"
                           TextColor="#E27575" VerticalOptions="Center"/>
                    <Button Grid.Column="1" Text="{Binding ActionButtonText}"
                            Clicked="OnActionClicked"
                            BackgroundColor="{Binding ActionButtonColor}"
                            TextColor="White"
                            HeightRequest="32" Padding="14,0"
                            FontAttributes="Bold" FontSize="11"
                            CornerRadius="8"
                            IsVisible="{Binding ShowActionButton}"
                            HorizontalOptions="End"/>
                </Grid>
            </Grid>
        </Border>
    </SwipeView>

</ContentView>
