<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Cremory.App"
             xmlns:models="clr-namespace:Cremory.App.Models"
             xmlns:controls="clr-namespace:Cremory.App.Controls"
             x:Class="Cremory.App.OrdersPage"
             x:DataType="local:OrdersPage"
             Title="Orders"
             BackgroundColor="{StaticResource Gray50}">

    <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto, *" Padding="20" RowSpacing="14">

        <Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto, Auto" ColumnSpacing="8">
            <VerticalStackLayout>
                <Label Text="Orders" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Gray900}"/>
                <Label Text="Manage and track all orders" FontSize="13" TextColor="{StaticResource Gray500}" Margin="0,4,0,0"/>
            </VerticalStackLayout>
            <Button Grid.Column="1" Text="+ New" Clicked="OnNewOrderClicked"
                    BackgroundColor="{StaticResource Success}" TextColor="White"
                    FontAttributes="Bold" HeightRequest="40" Padding="14,0" VerticalOptions="End"/>
            <Button Grid.Column="2" Text="Copy" Clicked="OnCopyTemplate"
                    BackgroundColor="{StaticResource Info}" TextColor="White"
                    FontAttributes="Bold" HeightRequest="40" Padding="14,0" VerticalOptions="End"/>
            <Button Grid.Column="3" Text="Import" Clicked="OnImportClicked"
                    BackgroundColor="{StaticResource Primary}" TextColor="White"
                    FontAttributes="Bold" HeightRequest="40" Padding="14,0" VerticalOptions="End"/>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*, *, *, *" ColumnSpacing="10">
            <Border Grid.Column="0" StrokeShape="RoundRectangle 10" BackgroundColor="{StaticResource Warning}"
                    Padding="12" Stroke="Transparent">
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                    <Label Text="{Binding PendingCount}" FontSize="22" FontAttributes="Bold"
                           TextColor="White" HorizontalTextAlignment="Center"/>
                    <Label Text="Pending" FontSize="11" TextColor="White" Opacity="0.85"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Border>
            <Border Grid.Column="1" StrokeShape="RoundRectangle 10" BackgroundColor="{StaticResource Info}"
                    Padding="12" Stroke="Transparent">
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                    <Label Text="{Binding PreparingCount}" FontSize="22" FontAttributes="Bold"
                           TextColor="White" HorizontalTextAlignment="Center"/>
                    <Label Text="Preparing" FontSize="11" TextColor="White" Opacity="0.85"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Border>
            <Border Grid.Column="2" StrokeShape="RoundRectangle 10" BackgroundColor="{StaticResource Success}"
                    Padding="12" Stroke="Transparent">
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                    <Label Text="{Binding CompletedCount}" FontSize="22" FontAttributes="Bold"
                           TextColor="White" HorizontalTextAlignment="Center"/>
                    <Label Text="Completed" FontSize="11" TextColor="White" Opacity="0.85"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Border>
            <Border Grid.Column="3" StrokeShape="RoundRectangle 10" BackgroundColor="{StaticResource Primary}"
                    Padding="12" Stroke="Transparent">
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                    <Label Text="{Binding TotalOrders}" FontSize="22" FontAttributes="Bold"
                           TextColor="White" HorizontalTextAlignment="Center"/>
                    <Label Text="Total" FontSize="11" TextColor="White" Opacity="0.85"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="Auto, Auto, Auto, Auto, *, Auto" ColumnSpacing="6">
            <Button Grid.Column="0" x:Name="FilterAll" Text="All"
                    Clicked="OnFilterClicked" BackgroundColor="{StaticResource Primary}"
                    TextColor="White" HeightRequest="36" Padding="14,0" FontSize="12" FontAttributes="Bold"/>
            <Button Grid.Column="1" x:Name="FilterPending" Text="Pending"
                    Clicked="OnFilterClicked" BackgroundColor="{StaticResource Gray200}"
                    TextColor="{StaticResource Gray700}" HeightRequest="36" Padding="14,0" FontSize="12"/>
            <Button Grid.Column="2" x:Name="FilterPreparing" Text="Preparing"
                    Clicked="OnFilterClicked" BackgroundColor="{StaticResource Gray200}"
                    TextColor="{StaticResource Gray700}" HeightRequest="36" Padding="14,0" FontSize="12"/>
            <Button Grid.Column="3" x:Name="FilterCompleted" Text="Completed"
                    Clicked="OnFilterClicked" BackgroundColor="{StaticResource Gray200}"
                    TextColor="{StaticResource Gray700}" HeightRequest="36" Padding="14,0" FontSize="12"/>
            <Button Grid.Column="5" x:Name="ArchiveToggle" Text="Show Archives"
                    Clicked="OnToggleArchives"
                    BackgroundColor="{StaticResource Gray200}"
                    TextColor="{StaticResource Gray700}" HeightRequest="36" Padding="14,0" FontSize="12"/>
        </Grid>

        <Border Grid.Row="3" StrokeShape="RoundRectangle 10" BackgroundColor="White"
                Padding="8" StrokeThickness="1" Stroke="{StaticResource Gray200}">
            <SearchBar x:Name="OrderSearchBar" Placeholder="Search by name or ID..."
                       TextChanged="OnSearchTextChanged"
                       BackgroundColor="{StaticResource Gray50}"/>
        </Border>

        <Grid Grid.Row="4" x:Name="ArchiveFilterBar" ColumnDefinitions="*, *" ColumnSpacing="10" IsVisible="False">
            <Border StrokeShape="RoundRectangle 10" BackgroundColor="White" Padding="8"
                    StrokeThickness="1" Stroke="{StaticResource Gray200}">
                <Picker x:Name="DateRangePicker" Title="Date Range" TextColor="{StaticResource Gray900}"
                        TitleColor="{StaticResource Gray500}" BackgroundColor="{StaticResource Gray50}"
                        SelectedIndexChanged="OnDateFilterChanged">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>Today</x:String>
                            <x:String>This Week</x:String>
                            <x:String>This Month</x:String>
                            <x:String>All Time</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
            </Border>
            <Border Grid.Column="1" StrokeShape="RoundRectangle 10" BackgroundColor="White" Padding="8"
                    StrokeThickness="1" Stroke="{StaticResource Gray200}">
                <Picker x:Name="ArchiveStatusPicker" Title="Status" TextColor="{StaticResource Gray900}"
                        TitleColor="{StaticResource Gray500}" BackgroundColor="{StaticResource Gray50}"
                        SelectedIndexChanged="OnDateFilterChanged">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>All</x:String>
                            <x:String>Completed</x:String>
                            <x:String>Cancelled</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
            </Border>
        </Grid>

        <RefreshView Grid.Row="5" x:Name="OrdersRefreshView" Refreshing="OnRefreshing">
            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"
                               Color="{StaticResource Primary}" VerticalOptions="Center" HorizontalOptions="Center"/>

            <CollectionView x:Name="OrdersCollectionView"
                            ItemsSource="{Binding FilteredOrders}">
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                        <Label Text="No orders found" FontSize="20" FontAttributes="Bold"
                               TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                        <Label Text="Tap + New to create a walk-in order"
                               FontSize="13" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:OrderSummary">
                        <controls:OrderCardView Margin="0,0,0,2"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>

</ContentPage>
