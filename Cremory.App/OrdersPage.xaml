<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Cremory.App"
             xmlns:models="clr-namespace:Cremory.App.Models"
             xmlns:controls="clr-namespace:Cremory.App.Controls"
             x:Class="Cremory.App.OrdersPage"
             x:DataType="local:OrdersPage"
             Title="Orders"
             BackgroundColor="{StaticResource Gray50}">

    <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto, *" Padding="16" RowSpacing="10">

        <Border x:Name="NewOrderAlert" Grid.Row="0" StrokeShape="RoundRectangle 12"
                BackgroundColor="{StaticResource Danger}" Stroke="Transparent"
                Padding="12" IsVisible="False">
            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                <VerticalStackLayout Spacing="1">
                    <Label x:Name="AlertTitle" Text="New Order Received!" FontSize="14"
                           FontAttributes="Bold" TextColor="White"/>
                    <Label x:Name="AlertMessage" Text="" FontSize="11" TextColor="White" Opacity="0.9"
                           LineBreakMode="TailTruncation" MaxLines="1"/>
                </VerticalStackLayout>
                <Label Grid.Column="1" Text="✕" FontSize="16" TextColor="White" VerticalOptions="Center"
                       Padding="6">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDismissAlert"/>
                    </Label.GestureRecognizers>
                </Label>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*, Auto, Auto, Auto" ColumnSpacing="8">
            <VerticalStackLayout Spacing="2">
                <Label Text="Orders" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Gray900}"/>
                <Label Text="Manage and track all orders" FontSize="12" TextColor="{StaticResource Gray500}"/>
            </VerticalStackLayout>
            <Border Grid.Column="1" StrokeShape="RoundRectangle 8" BackgroundColor="{StaticResource Success}"
                    Stroke="Transparent" HeightRequest="36" VerticalOptions="End">
                <Button Text="+ New" Clicked="OnNewOrderClicked"
                        BackgroundColor="Transparent" TextColor="White"
                        FontAttributes="Bold" FontSize="13" Padding="14,0"/>
            </Border>
            <Border Grid.Column="2" StrokeShape="RoundRectangle 8"
                    BackgroundColor="{StaticResource Gray100}" Stroke="{StaticResource Gray300}"
                    StrokeThickness="1" HeightRequest="36" VerticalOptions="End">
                <Button Text="Copy" Clicked="OnCopyTemplate"
                        BackgroundColor="Transparent" TextColor="{StaticResource Gray700}"
                        FontSize="12" Padding="12,0"/>
            </Border>
            <Border Grid.Column="3" StrokeShape="RoundRectangle 8"
                    BackgroundColor="{StaticResource Gray100}" Stroke="{StaticResource Gray300}"
                    StrokeThickness="1" HeightRequest="36" VerticalOptions="End">
                <Button Text="Import" Clicked="OnImportClicked"
                        BackgroundColor="Transparent" TextColor="{StaticResource Gray700}"
                        FontSize="12" Padding="12,0"/>
            </Border>
        </Grid>

        <ScrollView Grid.Row="2" Orientation="Horizontal" HorizontalScrollBarVisibility="Never"
                     VerticalOptions="Start">
            <HorizontalStackLayout Spacing="6">
                <Border StrokeShape="RoundRectangle 10" BackgroundColor="{StaticResource Warning}"
                        WidthRequest="100" Padding="10,12" Stroke="Transparent">
                    <Grid RowDefinitions="Auto, Auto" RowSpacing="1" HorizontalOptions="Center">
                        <Label Grid.Row="0" Text="{Binding PendingCount}" FontSize="18" FontAttributes="Bold"
                               TextColor="White" HorizontalTextAlignment="Center"/>
                        <Label Grid.Row="1" Text="Pending" FontSize="10" TextColor="White" Opacity="0.85"
                               HorizontalTextAlignment="Center"/>
                    </Grid>
                </Border>
                <Border StrokeShape="RoundRectangle 10" BackgroundColor="{StaticResource Info}"
                        WidthRequest="100" Padding="10,12" Stroke="Transparent">
                    <Grid RowDefinitions="Auto, Auto" RowSpacing="1" HorizontalOptions="Center">
                        <Label Grid.Row="0" Text="{Binding PreparingCount}" FontSize="18" FontAttributes="Bold"
                               TextColor="White" HorizontalTextAlignment="Center"/>
                        <Label Grid.Row="1" Text="Preparing" FontSize="10" TextColor="White" Opacity="0.85"
                               HorizontalTextAlignment="Center"/>
                    </Grid>
                </Border>
                <Border StrokeShape="RoundRectangle 10" BackgroundColor="{StaticResource Success}"
                        WidthRequest="100" Padding="10,12" Stroke="Transparent">
                    <Grid RowDefinitions="Auto, Auto" RowSpacing="1" HorizontalOptions="Center">
                        <Label Grid.Row="0" Text="{Binding CompletedCount}" FontSize="18" FontAttributes="Bold"
                               TextColor="White" HorizontalTextAlignment="Center"/>
                        <Label Grid.Row="1" Text="Completed" FontSize="10" TextColor="White" Opacity="0.85"
                               HorizontalTextAlignment="Center"/>
                    </Grid>
                </Border>
                <Border StrokeShape="RoundRectangle 10" BackgroundColor="{StaticResource Primary}"
                        WidthRequest="100" Padding="10,12" Stroke="Transparent">
                    <Grid RowDefinitions="Auto, Auto" RowSpacing="1" HorizontalOptions="Center">
                        <Label Grid.Row="0" Text="{Binding TotalOrders}" FontSize="18" FontAttributes="Bold"
                               TextColor="White" HorizontalTextAlignment="Center"/>
                        <Label Grid.Row="1" Text="Total" FontSize="10" TextColor="White" Opacity="0.85"
                               HorizontalTextAlignment="Center"/>
                    </Grid>
                </Border>
            </HorizontalStackLayout>
        </ScrollView>

        <Border Grid.Row="3" StrokeShape="RoundRectangle 10" BackgroundColor="White"
                Padding="4,0,8,0" StrokeThickness="1" Stroke="{StaticResource Gray200}">
            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="6">
                <ScrollView Grid.Column="0" Orientation="Horizontal" HorizontalScrollBarVisibility="Never"
                            VerticalOptions="Center">
                    <HorizontalStackLayout Spacing="4">
                        <Border x:Name="FilterAllBorder" StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource Primary}" Stroke="Transparent">
                            <Button x:Name="FilterAll" Text="All" Clicked="OnFilterClicked"
                                    BackgroundColor="Transparent" TextColor="White"
                                    FontSize="11" FontAttributes="Bold" Padding="12,0" HeightRequest="30"/>
                        </Border>
                        <Border x:Name="FilterPendingBorder" StrokeShape="RoundRectangle 14"
                                BackgroundColor="Transparent" Stroke="{StaticResource Gray300}" StrokeThickness="1">
                            <Button x:Name="FilterPending" Text="Pending" Clicked="OnFilterClicked"
                                    BackgroundColor="Transparent" TextColor="{StaticResource Gray600}"
                                    FontSize="11" Padding="12,0" HeightRequest="30"/>
                        </Border>
                        <Border x:Name="FilterPreparingBorder" StrokeShape="RoundRectangle 14"
                                BackgroundColor="Transparent" Stroke="{StaticResource Gray300}" StrokeThickness="1">
                            <Button x:Name="FilterPreparing" Text="Preparing" Clicked="OnFilterClicked"
                                    BackgroundColor="Transparent" TextColor="{StaticResource Gray600}"
                                    FontSize="11" Padding="12,0" HeightRequest="30"/>
                        </Border>
                        <Border x:Name="FilterCompletedBorder" StrokeShape="RoundRectangle 14"
                                BackgroundColor="Transparent" Stroke="{StaticResource Gray300}" StrokeThickness="1">
                            <Button x:Name="FilterCompleted" Text="Completed" Clicked="OnFilterClicked"
                                    BackgroundColor="Transparent" TextColor="{StaticResource Gray600}"
                                    FontSize="11" Padding="12,0" HeightRequest="30"/>
                        </Border>
                        <Border x:Name="KitchenViewBorder" StrokeShape="RoundRectangle 14"
                                BackgroundColor="Transparent" Stroke="{StaticResource Gray300}" StrokeThickness="1">
                            <Button x:Name="KitchenViewBtn" Text="Kitchen" Clicked="OnKitchenViewClicked"
                                    BackgroundColor="Transparent" TextColor="{StaticResource Gray600}"
                                    FontSize="11" Padding="12,0" HeightRequest="30"/>
                        </Border>
                    </HorizontalStackLayout>
                </ScrollView>
                <SearchBar x:Name="OrderSearchBar" Grid.Column="1" Placeholder="Search..."
                           TextChanged="OnSearchTextChanged"
                           BackgroundColor="{StaticResource Gray50}" HeightRequest="36"
                           FontSize="12"/>
                <HorizontalStackLayout Grid.Column="2" Spacing="4" VerticalOptions="Center">
                    <Label Text="Arch." FontSize="10" TextColor="{StaticResource Gray500}"
                           VerticalOptions="Center"/>
                    <Switch x:Name="ArchiveToggle" IsToggled="False" Toggled="OnToggleArchives"
                            VerticalOptions="Center" Scale="0.7"/>
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <Grid Grid.Row="4" x:Name="ArchiveFilterBar" ColumnDefinitions="*, *" ColumnSpacing="8" IsVisible="False">
            <Border StrokeShape="RoundRectangle 8" BackgroundColor="White" Padding="6"
                    StrokeThickness="1" Stroke="{StaticResource Gray200}">
                <Picker x:Name="DateRangePicker" Title="Date" TextColor="{StaticResource Gray900}"
                        TitleColor="{StaticResource Gray500}" BackgroundColor="{StaticResource Gray50}"
                        FontSize="12"
                        SelectedIndexChanged="OnDateFilterChanged">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>Today</x:String>
                            <x:String>This Week</x:String>
                            <x:String>This Month</x:String>
                            <x:String>All Time</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
            </Border>
            <Border Grid.Column="1" StrokeShape="RoundRectangle 8" BackgroundColor="White" Padding="6"
                    StrokeThickness="1" Stroke="{StaticResource Gray200}">
                <Picker x:Name="ArchiveStatusPicker" Title="Status" TextColor="{StaticResource Gray900}"
                        TitleColor="{StaticResource Gray500}" BackgroundColor="{StaticResource Gray50}"
                        FontSize="12"
                        SelectedIndexChanged="OnDateFilterChanged">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>All</x:String>
                            <x:String>Completed</x:String>
                            <x:String>Cancelled</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
            </Border>
        </Grid>

        <RefreshView Grid.Row="5" x:Name="OrdersRefreshView" Refreshing="OnRefreshing">
            <Grid>
                <CollectionView x:Name="OrdersCollectionView"
                                ItemsSource="{Binding FilteredOrders}"
                                RemainingItemsThreshold="5"
                                RemainingItemsThresholdReached="OnLoadMore">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8"
                                             Padding="0,40">
                            <Label Text="No orders found" FontSize="18" FontAttributes="Bold"
                                   TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                            <Label Text="Tap + New to create a walk-in order"
                                   FontSize="12" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:OrderSummary">
                            <controls:OrderCardView Margin="0,0,0,2"/>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <CollectionView x:Name="KitchenCollectionView" IsVisible="False">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8"
                                             Padding="0,40">
                            <Label Text="No pending orders" FontSize="18" FontAttributes="Bold"
                                   TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                            <Label Text="Pending orders appear here for batch prep"
                                   FontSize="12" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="local:KitchenItemGroup">
                            <Border StrokeShape="RoundRectangle 10" StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}" Padding="12" Margin="0,0,0,6"
                                    BackgroundColor="White">
                                <Grid ColumnDefinitions="36, *, Auto" ColumnSpacing="10">
                                    <Border StrokeShape="RoundRectangle 6" WidthRequest="36" HeightRequest="36"
                                            BackgroundColor="{StaticResource PrimaryLight}" Stroke="Transparent"
                                            VerticalOptions="Center" HorizontalOptions="Center">
                                        <Label Text="{Binding TotalQty}" FontSize="15" FontAttributes="Bold"
                                               TextColor="{StaticResource PrimaryDark}" HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                        <Label Text="{Binding ItemName}" FontSize="14" FontAttributes="Bold"
                                               TextColor="{StaticResource Gray900}" LineBreakMode="TailTruncation" MaxLines="1"/>
                                        <Label Text="{Binding OrderCount, StringFormat='From {0} order(s)'}"
                                               FontSize="10" TextColor="{StaticResource Gray500}"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="{Binding TotalQty, StringFormat='x{0}'}"
                                           FontSize="18" FontAttributes="Bold"
                                           TextColor="{StaticResource PrimaryDark}" VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <VerticalStackLayout x:Name="SkeletonLoading" Spacing="8" Padding="0" IsVisible="False">
                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="{StaticResource Gray100}"
                            Stroke="Transparent" Padding="14" HeightRequest="80">
                        <Grid ColumnDefinitions="40, *" ColumnSpacing="12">
                            <BoxView CornerRadius="20" WidthRequest="40" HeightRequest="40"
                                     Color="{StaticResource Gray200}" VerticalOptions="Start"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                <BoxView CornerRadius="3" HeightRequest="12" WidthRequest="160"
                                         Color="{StaticResource Gray200}" HorizontalOptions="Start"/>
                                <BoxView CornerRadius="3" HeightRequest="8" WidthRequest="100"
                                         Color="{StaticResource Gray200}" HorizontalOptions="Start"/>
                                <BoxView CornerRadius="3" HeightRequest="8" WidthRequest="80"
                                         Color="{StaticResource Gray200}" HorizontalOptions="Start"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="{StaticResource Gray100}"
                            Stroke="Transparent" Padding="14" HeightRequest="80">
                        <Grid ColumnDefinitions="40, *" ColumnSpacing="12">
                            <BoxView CornerRadius="20" WidthRequest="40" HeightRequest="40"
                                     Color="{StaticResource Gray200}" VerticalOptions="Start"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                <BoxView CornerRadius="3" HeightRequest="12" WidthRequest="140"
                                         Color="{StaticResource Gray200}" HorizontalOptions="Start"/>
                                <BoxView CornerRadius="3" HeightRequest="8" WidthRequest="90"
                                         Color="{StaticResource Gray200}" HorizontalOptions="Start"/>
                                <BoxView CornerRadius="3" HeightRequest="8" WidthRequest="70"
                                         Color="{StaticResource Gray200}" HorizontalOptions="Start"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="{StaticResource Gray100}"
                            Stroke="Transparent" Padding="14" HeightRequest="80">
                        <Grid ColumnDefinitions="40, *" ColumnSpacing="12">
                            <BoxView CornerRadius="20" WidthRequest="40" HeightRequest="40"
                                     Color="{StaticResource Gray200}" VerticalOptions="Start"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                <BoxView CornerRadius="3" HeightRequest="12" WidthRequest="150"
                                         Color="{StaticResource Gray200}" HorizontalOptions="Start"/>
                                <BoxView CornerRadius="3" HeightRequest="8" WidthRequest="110"
                                         Color="{StaticResource Gray200}" HorizontalOptions="Start"/>
                                <BoxView CornerRadius="3" HeightRequest="8" WidthRequest="90"
                                         Color="{StaticResource Gray200}" HorizontalOptions="Start"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </Grid>
        </RefreshView>
    </Grid>

</ContentPage>
