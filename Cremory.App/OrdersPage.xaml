<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Cremory.App"
             xmlns:models="clr-namespace:Cremory.App.Models"
             xmlns:controls="clr-namespace:Cremory.App.Controls"
             x:Class="Cremory.App.OrdersPage"
             x:DataType="local:OrdersPage"
             Title="Orders"
             BackgroundColor="{StaticResource Gray50}">

    <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, *" Padding="20" RowSpacing="14">

        <Border x:Name="NewOrderAlert" Grid.Row="0" StrokeShape="RoundRectangle 12"
                BackgroundColor="{StaticResource Danger}" Stroke="Transparent"
                Padding="16" IsVisible="False">
            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                <VerticalStackLayout Spacing="2">
                    <Label x:Name="AlertTitle" Text="New Order Received!" FontSize="15"
                           FontAttributes="Bold" TextColor="White"/>
                    <Label x:Name="AlertMessage" Text="" FontSize="12" TextColor="White" Opacity="0.9"/>
                </VerticalStackLayout>
                <Label Grid.Column="1" Text="✕" FontSize="18" TextColor="White" VerticalOptions="Center"
                       Padding="8">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDismissAlert"/>
                    </Label.GestureRecognizers>
                </Label>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*, Auto, Auto, Auto" ColumnSpacing="10">
            <VerticalStackLayout>
                <Label Text="Orders" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Gray900}"/>
                <Label Text="Manage and track all orders" FontSize="13" TextColor="{StaticResource Gray500}" Margin="0,4,0,0"/>
            </VerticalStackLayout>
            <Border Grid.Column="1" StrokeShape="RoundRectangle 10" BackgroundColor="{StaticResource Success}"
                    Stroke="Transparent" HeightRequest="40" VerticalOptions="End">
                <Button Text="+ New" Clicked="OnNewOrderClicked"
                        BackgroundColor="Transparent" TextColor="White"
                        FontAttributes="Bold" FontSize="14" Padding="16,0"/>
            </Border>
            <Border Grid.Column="2" StrokeShape="RoundRectangle 10"
                    BackgroundColor="{StaticResource Gray100}" Stroke="{StaticResource Gray300}"
                    StrokeThickness="1" HeightRequest="40" VerticalOptions="End">
                <Button Text="Copy" Clicked="OnCopyTemplate"
                        BackgroundColor="Transparent" TextColor="{StaticResource Gray700}"
                        FontSize="13" Padding="14,0"/>
            </Border>
            <Border Grid.Column="3" StrokeShape="RoundRectangle 10"
                    BackgroundColor="{StaticResource Gray100}" Stroke="{StaticResource Gray300}"
                    StrokeThickness="1" HeightRequest="40" VerticalOptions="End">
                <Button Text="Import" Clicked="OnImportClicked"
                        BackgroundColor="Transparent" TextColor="{StaticResource Gray700}"
                        FontSize="13" Padding="14,0"/>
            </Border>
        </Grid>

        <ScrollView Grid.Row="2" Orientation="Horizontal" HorizontalScrollBarVisibility="Never"
                     VerticalOptions="Start">
            <HorizontalStackLayout Spacing="8" Padding="0">
                <Border StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource Warning}"
                        WidthRequest="130" Padding="14,16" Stroke="Transparent">
                    <Grid RowDefinitions="Auto, Auto" RowSpacing="2" HorizontalOptions="Center">
                        <Label Grid.Row="0" Text="{Binding PendingCount}" FontSize="20" FontAttributes="Bold"
                               TextColor="White" HorizontalTextAlignment="Center" LineBreakMode="NoWrap"/>
                        <Label Grid.Row="1" Text="Pending" FontSize="11" TextColor="White" Opacity="0.85"
                               HorizontalTextAlignment="Center" LineBreakMode="NoWrap"/>
                    </Grid>
                </Border>
                <Border StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource Info}"
                        WidthRequest="130" Padding="14,16" Stroke="Transparent">
                    <Grid RowDefinitions="Auto, Auto" RowSpacing="2" HorizontalOptions="Center">
                        <Label Grid.Row="0" Text="{Binding PreparingCount}" FontSize="20" FontAttributes="Bold"
                               TextColor="White" HorizontalTextAlignment="Center" LineBreakMode="NoWrap"/>
                        <Label Grid.Row="1" Text="Preparing" FontSize="11" TextColor="White" Opacity="0.85"
                               HorizontalTextAlignment="Center" LineBreakMode="NoWrap"/>
                    </Grid>
                </Border>
                <Border StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource Success}"
                        WidthRequest="130" Padding="14,16" Stroke="Transparent">
                    <Grid RowDefinitions="Auto, Auto" RowSpacing="2" HorizontalOptions="Center">
                        <Label Grid.Row="0" Text="{Binding CompletedCount}" FontSize="20" FontAttributes="Bold"
                               TextColor="White" HorizontalTextAlignment="Center" LineBreakMode="NoWrap"/>
                        <Label Grid.Row="1" Text="Completed" FontSize="11" TextColor="White" Opacity="0.85"
                               HorizontalTextAlignment="Center" LineBreakMode="NoWrap"/>
                    </Grid>
                </Border>
                <Border StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource Primary}"
                        WidthRequest="130" Padding="14,16" Stroke="Transparent">
                    <Grid RowDefinitions="Auto, Auto" RowSpacing="2" HorizontalOptions="Center">
                        <Label Grid.Row="0" Text="{Binding TotalOrders}" FontSize="20" FontAttributes="Bold"
                               TextColor="White" HorizontalTextAlignment="Center" LineBreakMode="NoWrap"/>
                        <Label Grid.Row="1" Text="Total" FontSize="11" TextColor="White" Opacity="0.85"
                               HorizontalTextAlignment="Center" LineBreakMode="NoWrap"/>
                    </Grid>
                </Border>
            </HorizontalStackLayout>
        </ScrollView>

        <ScrollView Grid.Row="3" Orientation="Horizontal" HorizontalOptions="Start" VerticalOptions="Center">
            <HorizontalStackLayout Spacing="8">
                <Border x:Name="FilterAllBorder" StrokeShape="RoundRectangle 18"
                        BackgroundColor="{StaticResource Primary}" Stroke="Transparent">
                    <Button x:Name="FilterAll" Text="All" Clicked="OnFilterClicked"
                            BackgroundColor="Transparent" TextColor="White"
                            FontSize="12" FontAttributes="Bold" Padding="16,0" HeightRequest="36"/>
                </Border>
                <Border x:Name="FilterPendingBorder" StrokeShape="RoundRectangle 18"
                        BackgroundColor="Transparent" Stroke="{StaticResource Gray300}" StrokeThickness="1">
                    <Button x:Name="FilterPending" Text="Pending" Clicked="OnFilterClicked"
                            BackgroundColor="Transparent" TextColor="{StaticResource Gray600}"
                            FontSize="12" Padding="16,0" HeightRequest="36"/>
                </Border>
                <Border x:Name="FilterPreparingBorder" StrokeShape="RoundRectangle 18"
                        BackgroundColor="Transparent" Stroke="{StaticResource Gray300}" StrokeThickness="1">
                    <Button x:Name="FilterPreparing" Text="Preparing" Clicked="OnFilterClicked"
                            BackgroundColor="Transparent" TextColor="{StaticResource Gray600}"
                            FontSize="12" Padding="16,0" HeightRequest="36"/>
                </Border>
                <Border x:Name="FilterCompletedBorder" StrokeShape="RoundRectangle 18"
                        BackgroundColor="Transparent" Stroke="{StaticResource Gray300}" StrokeThickness="1">
                    <Button x:Name="FilterCompleted" Text="Completed" Clicked="OnFilterClicked"
                            BackgroundColor="Transparent" TextColor="{StaticResource Gray600}"
                            FontSize="12" Padding="16,0" HeightRequest="36"/>
                </Border>
                <Border x:Name="KitchenViewBorder" StrokeShape="RoundRectangle 18"
                        BackgroundColor="Transparent" Stroke="{StaticResource Gray300}" StrokeThickness="1">
                    <Button x:Name="KitchenViewBtn" Text="Kitchen View" Clicked="OnKitchenViewClicked"
                            BackgroundColor="Transparent" TextColor="{StaticResource Gray600}"
                            FontSize="12" Padding="16,0" HeightRequest="36"/>
                </Border>
            </HorizontalStackLayout>
        </ScrollView>

        <Border Grid.Row="4" StrokeShape="RoundRectangle 10" BackgroundColor="White"
                Padding="0,0,12,0" StrokeThickness="1" Stroke="{StaticResource Gray200}">
            <Grid ColumnDefinitions="*, Auto" Padding="0">
                <SearchBar x:Name="OrderSearchBar" Placeholder="Search by name or ID..."
                           TextChanged="OnSearchTextChanged"
                           BackgroundColor="{StaticResource Gray50}"/>
                <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                    <Label Text="Archives" FontSize="12" TextColor="{StaticResource Gray500}"
                           VerticalOptions="Center"/>
                    <Switch x:Name="ArchiveToggle" IsToggled="False" Toggled="OnToggleArchives"
                            VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <Grid Grid.Row="5" x:Name="ArchiveFilterBar" ColumnDefinitions="*, *" ColumnSpacing="10" IsVisible="False">
            <Border StrokeShape="RoundRectangle 10" BackgroundColor="White" Padding="8"
                    StrokeThickness="1" Stroke="{StaticResource Gray200}">
                <Picker x:Name="DateRangePicker" Title="Date Range" TextColor="{StaticResource Gray900}"
                        TitleColor="{StaticResource Gray500}" BackgroundColor="{StaticResource Gray50}"
                        SelectedIndexChanged="OnDateFilterChanged">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>Today</x:String>
                            <x:String>This Week</x:String>
                            <x:String>This Month</x:String>
                            <x:String>All Time</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
            </Border>
            <Border Grid.Column="1" StrokeShape="RoundRectangle 10" BackgroundColor="White" Padding="8"
                    StrokeThickness="1" Stroke="{StaticResource Gray200}">
                <Picker x:Name="ArchiveStatusPicker" Title="Status" TextColor="{StaticResource Gray900}"
                        TitleColor="{StaticResource Gray500}" BackgroundColor="{StaticResource Gray50}"
                        SelectedIndexChanged="OnDateFilterChanged">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>All</x:String>
                            <x:String>Completed</x:String>
                            <x:String>Cancelled</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
            </Border>
        </Grid>

        <RefreshView Grid.Row="6" x:Name="OrdersRefreshView" Refreshing="OnRefreshing">

            <Grid>
            <CollectionView x:Name="OrdersCollectionView"
                            ItemsSource="{Binding FilteredOrders}"
                            RemainingItemsThreshold="5"
                            RemainingItemsThresholdReached="OnLoadMore">
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                        <Label Text="No orders found" FontSize="20" FontAttributes="Bold"
                               TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                        <Label Text="Tap + New to create a walk-in order"
                               FontSize="13" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:OrderSummary">
                        <controls:OrderCardView Margin="0,0,0,2"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <CollectionView x:Name="KitchenCollectionView" IsVisible="False">
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                        <Label Text="No pending orders" FontSize="20" FontAttributes="Bold"
                               TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                        <Label Text="Pending orders will appear here for batch prep"
                               FontSize="13" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local:KitchenItemGroup">
                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="1"
                                Stroke="{StaticResource Gray200}" Padding="14" Margin="0,0,0,8"
                                BackgroundColor="White">
                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
                                <Border StrokeShape="RoundRectangle 8" WidthRequest="44" HeightRequest="44"
                                        BackgroundColor="{StaticResource PrimaryLight}" Stroke="Transparent"
                                        VerticalOptions="Center" HorizontalOptions="Center">
                                    <Label Text="{Binding TotalQty}" FontSize="18" FontAttributes="Bold"
                                           TextColor="{StaticResource PrimaryDark}" HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding ItemName}" FontSize="16" FontAttributes="Bold"
                                           TextColor="{StaticResource Gray900}"/>
                                    <Label Text="{Binding OrderCount, StringFormat='From {0} order(s)'}"
                                           FontSize="11" TextColor="{StaticResource Gray500}"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="{Binding TotalQty, StringFormat='x{0}'}"
                                       FontSize="22" FontAttributes="Bold"
                                       TextColor="{StaticResource PrimaryDark}" VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <VerticalStackLayout x:Name="SkeletonLoading" Spacing="12" Padding="0" IsVisible="False">
                <Border StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource Gray100}"
                        Stroke="Transparent" Padding="16" HeightRequest="100">
                    <Grid ColumnDefinitions="44, *" ColumnSpacing="14">
                        <BoxView CornerRadius="22" WidthRequest="44" HeightRequest="44"
                                 Color="{StaticResource Gray200}" VerticalOptions="Start"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                            <BoxView CornerRadius="4" HeightRequest="14" WidthRequest="200"
                                     Color="{StaticResource Gray200}" HorizontalOptions="Start"/>
                            <BoxView CornerRadius="4" HeightRequest="10" WidthRequest="140"
                                     Color="{StaticResource Gray200}" HorizontalOptions="Start"/>
                            <BoxView CornerRadius="4" HeightRequest="10" WidthRequest="100"
                                     Color="{StaticResource Gray200}" HorizontalOptions="Start"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>
                <Border StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource Gray100}"
                        Stroke="Transparent" Padding="16" HeightRequest="100">
                    <Grid ColumnDefinitions="44, *" ColumnSpacing="14">
                        <BoxView CornerRadius="22" WidthRequest="44" HeightRequest="44"
                                 Color="{StaticResource Gray200}" VerticalOptions="Start"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                            <BoxView CornerRadius="4" HeightRequest="14" WidthRequest="180"
                                     Color="{StaticResource Gray200}" HorizontalOptions="Start"/>
                            <BoxView CornerRadius="4" HeightRequest="10" WidthRequest="120"
                                     Color="{StaticResource Gray200}" HorizontalOptions="Start"/>
                            <BoxView CornerRadius="4" HeightRequest="10" WidthRequest="90"
                                     Color="{StaticResource Gray200}" HorizontalOptions="Start"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>
                <Border StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource Gray100}"
                        Stroke="Transparent" Padding="16" HeightRequest="100">
                    <Grid ColumnDefinitions="44, *" ColumnSpacing="14">
                        <BoxView CornerRadius="22" WidthRequest="44" HeightRequest="44"
                                 Color="{StaticResource Gray200}" VerticalOptions="Start"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                            <BoxView CornerRadius="4" HeightRequest="14" WidthRequest="190"
                                     Color="{StaticResource Gray200}" HorizontalOptions="Start"/>
                            <BoxView CornerRadius="4" HeightRequest="10" WidthRequest="130"
                                     Color="{StaticResource Gray200}" HorizontalOptions="Start"/>
                            <BoxView CornerRadius="4" HeightRequest="10" WidthRequest="110"
                                     Color="{StaticResource Gray200}" HorizontalOptions="Start"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </VerticalStackLayout>
            </Grid>
        </RefreshView>
    </Grid>

</ContentPage>