<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Cremory.App"
             xmlns:models="clr-namespace:Cremory.App.Models"
             xmlns:controls="clr-namespace:Cremory.App.Controls"
             x:Class="Cremory.App.OrdersPage"
             x:DataType="local:OrdersPage"
             Title="Orders"
             BackgroundColor="#FFFDFD">

    <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto, *" Padding="16,14,16,0" RowSpacing="10">

        <Border x:Name="NewOrderAlert" Grid.Row="0"
                StrokeShape="RoundRectangle 10"
                BackgroundColor="#E27575" Stroke="Transparent"
                Padding="12" IsVisible="False">
            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                <VerticalStackLayout Spacing="1">
                    <Label x:Name="AlertTitle" Text="New Order!"
                           FontSize="13" FontAttributes="Bold" TextColor="White"/>
                    <Label x:Name="AlertMessage" Text="" FontSize="11"
                           TextColor="White" Opacity="0.85"
                           LineBreakMode="TailTruncation" MaxLines="1"/>
                </VerticalStackLayout>
                <Label Grid.Column="1" Text="X" FontSize="14" TextColor="White"
                       VerticalOptions="Center" Padding="6">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDismissAlert"/>
                    </Label.GestureRecognizers>
                </Label>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
            <Label Text="Orders" FontSize="26" FontAttributes="Bold"
                   TextColor="#2C2525" VerticalOptions="Center"/>
            <HorizontalStackLayout Grid.Column="1" Spacing="8" HorizontalOptions="Center"
                                   VerticalOptions="Center">
                <Label Text="{Binding PendingCount}" FontSize="14" FontAttributes="Bold"
                       TextColor="#E27575"/>
                <Label Text="pending" FontSize="12" TextColor="#B89292" VerticalOptions="Center"/>
                <Label Text="|" FontSize="12" TextColor="#E8D4D4" VerticalOptions="Center"/>
                <Label Text="{Binding PreparingCount}" FontSize="14" FontAttributes="Bold"
                       TextColor="#E27575"/>
                <Label Text="prep" FontSize="12" TextColor="#B89292" VerticalOptions="Center"/>
            </HorizontalStackLayout>
            <HorizontalStackLayout Grid.Column="2" Spacing="6" VerticalOptions="Center">
                <Border StrokeShape="RoundRectangle 8" BackgroundColor="#FBC4C4"
                        Stroke="Transparent" HeightRequest="34">
                    <Button Text="+ New" Clicked="OnNewOrderClicked"
                            BackgroundColor="Transparent" TextColor="White"
                            FontAttributes="Bold" FontSize="12" Padding="14,0"/>
                </Border>
            </HorizontalStackLayout>
        </Grid>

        <Border Grid.Row="2" StrokeShape="RoundRectangle 10"
                BackgroundColor="#FDF5F5" Stroke="Transparent" Padding="4,2">
            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="6">
                <SearchBar x:Name="OrderSearchBar" Placeholder="Search orders..."
                           TextChanged="OnSearchTextChanged"
                           BackgroundColor="Transparent" CancelButtonColor="#B89292"
                           TextColor="#2C2525" PlaceholderColor="#B89292"
                           FontSize="13" HeightRequest="32"/>
                <Border Grid.Column="1" x:Name="ArchiveToggleBtn"
                        StrokeShape="RoundRectangle 8"
                        BackgroundColor="Transparent" Stroke="#E8D4D4" StrokeThickness="1"
                        Padding="10,2" VerticalOptions="Center">
                    <Label x:Name="ArchiveLabel" Text="Archives" FontSize="11"
                           TextColor="#B89292" Padding="0" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnToggleArchives"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                StrokeShape="RoundRectangle 10"
                BackgroundColor="#FDF5F5" Stroke="Transparent"
                Padding="6">
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="4">
                    <Border x:Name="FilterAllBorder" StrokeShape="RoundRectangle 12"
                            BackgroundColor="#E27575" Stroke="Transparent">
                        <Button x:Name="FilterAll" Text="All" Clicked="OnFilterClicked"
                                BackgroundColor="Transparent" TextColor="White"
                                FontSize="11" FontAttributes="Bold" Padding="12,0" HeightRequest="28"/>
                    </Border>
                    <Border x:Name="FilterPendingBorder" StrokeShape="RoundRectangle 12"
                            BackgroundColor="Transparent"
                            Stroke="#E8D4D4" StrokeThickness="1">
                        <Button x:Name="FilterPending" Text="Pending" Clicked="OnFilterClicked"
                                BackgroundColor="Transparent" TextColor="#B89292"
                                FontSize="11" Padding="12,0" HeightRequest="28"/>
                    </Border>
                    <Border x:Name="FilterPreparingBorder" StrokeShape="RoundRectangle 12"
                            BackgroundColor="Transparent"
                            Stroke="#E8D4D4" StrokeThickness="1">
                        <Button x:Name="FilterPreparing" Text="Preparing" Clicked="OnFilterClicked"
                                BackgroundColor="Transparent" TextColor="#B89292"
                                FontSize="11" Padding="12,0" HeightRequest="28"/>
                    </Border>
                    <Border x:Name="FilterCompletedBorder" StrokeShape="RoundRectangle 12"
                            BackgroundColor="Transparent"
                            Stroke="#E8D4D4" StrokeThickness="1">
                        <Button x:Name="FilterCompleted" Text="Completed" Clicked="OnFilterClicked"
                                BackgroundColor="Transparent" TextColor="#B89292"
                                FontSize="11" Padding="12,0" HeightRequest="28"/>
                    </Border>
                    <Border x:Name="KitchenViewBorder" StrokeShape="RoundRectangle 12"
                            BackgroundColor="Transparent"
                            Stroke="#E8D4D4" StrokeThickness="1">
                        <Button x:Name="KitchenViewBtn" Text="Kitchen" Clicked="OnKitchenViewClicked"
                                BackgroundColor="Transparent" TextColor="#B89292"
                                FontSize="11" Padding="12,0" HeightRequest="28"/>
                    </Border>
                </HorizontalStackLayout>
            </ScrollView>
        </Border>

        <Border Grid.Row="4" x:Name="ArchiveFilterBar"
                StrokeShape="RoundRectangle 10"
                BackgroundColor="#FDF5F5" Stroke="Transparent"
                Padding="8" IsVisible="False">
            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                <Picker x:Name="DateRangePicker" Title="Date"
                        TextColor="#2C2525" TitleColor="#B89292"
                        BackgroundColor="White" FontSize="11"
                        SelectedIndexChanged="OnDateFilterChanged">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>Today</x:String>
                            <x:String>This Week</x:String>
                            <x:String>This Month</x:String>
                            <x:String>All Time</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
                <Picker Grid.Column="1" x:Name="ArchiveStatusPicker"
                        Title="Status" TextColor="#2C2525" TitleColor="#B89292"
                        BackgroundColor="White" FontSize="11" WidthRequest="120"
                        SelectedIndexChanged="OnDateFilterChanged">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>All</x:String>
                            <x:String>Completed</x:String>
                            <x:String>Cancelled</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
            </Grid>
        </Border>

        <RefreshView Grid.Row="5" x:Name="OrdersRefreshView" Refreshing="OnRefreshing"
                      RefreshColor="#E27575">
            <Grid>
                <CollectionView x:Name="OrdersCollectionView"
                                ItemsSource="{Binding FilteredOrders}"
                                RemainingItemsThreshold="5"
                                RemainingItemsThresholdReached="OnLoadMore">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center"
                                             Spacing="8" Padding="0,80">
                            <Label Text="No orders yet" FontSize="20" FontAttributes="Bold"
                                   TextColor="#D4B8B8" HorizontalTextAlignment="Center"/>
                            <Label Text="Tap the + button to create your first order"
                                   FontSize="13" TextColor="#D4B8B8"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:OrderSummary">
                            <controls:OrderCardView/>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <CollectionView x:Name="KitchenCollectionView" IsVisible="False">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center"
                                             Spacing="8" Padding="0,80">
                            <Label Text="Kitchen is clear" FontSize="20" FontAttributes="Bold"
                                   TextColor="#D4B8B8" HorizontalTextAlignment="Center"/>
                            <Label Text="No orders to prepare right now"
                                   FontSize="13" TextColor="#D4B8B8"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="local:KitchenItemGroup">
                            <Border StrokeShape="RoundRectangle 10"
                                    Stroke="#E8D4D4" StrokeThickness="1"
                                    Padding="12" Margin="0,0,0,6"
                                    BackgroundColor="White">
                                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                                    <Border StrokeShape="RoundRectangle 6"
                                            WidthRequest="34" HeightRequest="34"
                                            BackgroundColor="#FDE8E8" Stroke="Transparent"
                                            VerticalOptions="Center" HorizontalOptions="Center">
                                        <Label Text="{Binding TotalQty}" FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="#E27575" HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                        <Label Text="{Binding ItemName}" FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="#2C2525"
                                               LineBreakMode="TailTruncation" MaxLines="1"/>
                                        <Label Text="{Binding OrderCount, StringFormat='{0} order(s)'}"
                                               FontSize="10" TextColor="#B89292"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="{Binding TotalQty, StringFormat='x{0}'}"
                                           FontSize="18" FontAttributes="Bold"
                                           TextColor="#E27575" VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <VerticalStackLayout x:Name="SkeletonLoading" Spacing="10" Padding="0" IsVisible="False">
                    <Border StrokeShape="RoundRectangle 12" BackgroundColor="#FDF5F5"
                            Stroke="Transparent" Padding="16" HeightRequest="80">
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                            <VerticalStackLayout Spacing="6" VerticalOptions="Center">
                                <BoxView CornerRadius="3" HeightRequest="12" WidthRequest="120"
                                         Color="#F5E8E8" HorizontalOptions="Start"/>
                                <BoxView CornerRadius="3" HeightRequest="8" WidthRequest="80"
                                         Color="#F5E8E8" HorizontalOptions="Start"/>
                            </VerticalStackLayout>
                            <BoxView Grid.Column="1" CornerRadius="3" HeightRequest="28" WidthRequest="50"
                                     Color="#F5E8E8" VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                    <Border StrokeShape="RoundRectangle 12" BackgroundColor="#FDF5F5"
                            Stroke="Transparent" Padding="16" HeightRequest="80">
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                            <VerticalStackLayout Spacing="6" VerticalOptions="Center">
                                <BoxView CornerRadius="3" HeightRequest="12" WidthRequest="100"
                                         Color="#F5E8E8" HorizontalOptions="Start"/>
                                <BoxView CornerRadius="3" HeightRequest="8" WidthRequest="70"
                                         Color="#F5E8E8" HorizontalOptions="Start"/>
                            </VerticalStackLayout>
                            <BoxView Grid.Column="1" CornerRadius="3" HeightRequest="28" WidthRequest="50"
                                     Color="#F5E8E8" VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                    <Border StrokeShape="RoundRectangle 12" BackgroundColor="#FDF5F5"
                            Stroke="Transparent" Padding="16" HeightRequest="80">
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                            <VerticalStackLayout Spacing="6" VerticalOptions="Center">
                                <BoxView CornerRadius="3" HeightRequest="12" WidthRequest="110"
                                         Color="#F5E8E8" HorizontalOptions="Start"/>
                                <BoxView CornerRadius="3" HeightRequest="8" WidthRequest="90"
                                         Color="#F5E8E8" HorizontalOptions="Start"/>
                            </VerticalStackLayout>
                            <BoxView Grid.Column="1" CornerRadius="3" HeightRequest="28" WidthRequest="50"
                                     Color="#F5E8E8" VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </Grid>
        </RefreshView>
    </Grid>

</ContentPage>
