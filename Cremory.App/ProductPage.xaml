<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Cremory.App.Models"
             x:Class="Cremory.App.ProductPage"
             Title="Products"
             BackgroundColor="{StaticResource Gray50}">

    <Grid RowDefinitions="Auto, Auto, *" Padding="20" RowSpacing="16">
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" ColumnSpacing="12">
            <VerticalStackLayout>
                <Label Text="Products" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Gray900}"/>
                <Label Text="Menu items, variants, and pricing" FontSize="13" TextColor="{StaticResource Gray500}" Margin="0,4,0,0"/>
            </VerticalStackLayout>
            <Button Grid.Column="1" Text="+ Add" Clicked="OnAddClicked"
                    BackgroundColor="{StaticResource Success}" TextColor="White"
                    FontAttributes="Bold" HeightRequest="40" Padding="14,0" VerticalOptions="End"/>
        </Grid>

        <Border Grid.Row="1" StrokeShape="RoundRectangle 10" BackgroundColor="White"
                Padding="8" StrokeThickness="1" Stroke="{StaticResource Gray200}">
            <SearchBar x:Name="ProductSearchBar" Placeholder="Search products..."
                       TextChanged="OnSearchTextChanged"
                       BackgroundColor="{StaticResource Gray50}"/>
        </Border>

        <RefreshView Grid.Row="2" x:Name="ProductRefreshView" Refreshing="OnRefreshing">
        <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False"
                           Color="{StaticResource Primary}" VerticalOptions="Center" HorizontalOptions="Center"/>

        <CollectionView x:Name="ProductsCollectionView">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                    <Label Text="No products yet" FontSize="20" FontAttributes="Bold"
                           TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                    <Label Text="Tap + Add to create your first product"
                           FontSize="13" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Product">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Toggle Active" BackgroundColor="{StaticResource Warning}"
                                           Invoked="OnToggleActiveSwipe"/>
                                <SwipeItem Text="Edit" BackgroundColor="{StaticResource Info}"
                                           Invoked="OnEditSwipe"/>
                                <SwipeItem Text="Delete" BackgroundColor="{StaticResource Danger}"
                                           Invoked="OnDeleteSwipe"/>
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="1"
                                Stroke="{StaticResource Gray200}" Padding="16" Margin="0,0,0,10"
                                Opacity="{Binding ActiveOpacity}"
                                BackgroundColor="White">
                            <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto" RowSpacing="6">
                                <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="8">
                                    <Label FontSize="16" FontAttributes="Bold"
                                           TextColor="{StaticResource Gray900}"
                                           Text="{Binding Name}"/>
                                    <Border StrokeShape="RoundRectangle 6" Padding="6,2"
                                            BackgroundColor="{StaticResource Gray400}"
                                            Stroke="Transparent"
                                            IsVisible="{Binding IsInactive}">
                                        <Label Text="Inactive" FontSize="9" FontAttributes="Bold"
                                               TextColor="White"/>
                                    </Border>
                                </HorizontalStackLayout>
                                <Label Grid.Row="0" Grid.Column="1" FontSize="18" FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}" HorizontalOptions="End"
                                       Text="{Binding BasePrice, StringFormat='₱{0:N0}'}"/>
                                <Label Grid.Row="1" Grid.ColumnSpan="2" FontSize="12"
                                       TextColor="{StaticResource Gray500}">
                                    <Label.Text>
                                        <MultiBinding StringFormat="{}{0} · {1}">
                                            <Binding Path="Variant"/>
                                            <Binding Path="Flavor"/>
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                                <Label Grid.Row="2" Grid.ColumnSpan="2" FontSize="11"
                                       TextColor="{StaticResource Gray400}">
                                    <Label.Text>
                                        <MultiBinding StringFormat="Order: {0} | ID: {1}">
                                            <Binding Path="DisplayOrder"/>
                                            <Binding Path="ProductId"/>
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        </RefreshView>
    </Grid>

</ContentPage>
