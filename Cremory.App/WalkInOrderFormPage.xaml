<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Cremory.App"
             x:Class="Cremory.App.WalkInOrderFormPage"
             Title="New Walk-in Order"
             BackgroundColor="{StaticResource Gray50}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <Grid ColumnDefinitions="*, Auto">
                <VerticalStackLayout Spacing="4">
                    <Label Text="New Walk-in Order" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource Gray900}"/>
                    <Label Text="Create an order directly" FontSize="12" TextColor="{StaticResource Gray500}"/>
                </VerticalStackLayout>
                <Border Grid.Column="1" StrokeShape="RoundRectangle 6"
                        BackgroundColor="#FDF5F5" Stroke="#E8D4D4" StrokeThickness="1"
                        Padding="8,4" VerticalOptions="Start">
                    <Label Text="Copy Template" FontSize="10" FontAttributes="Bold"
                           TextColor="#7D5A5A" Padding="4,0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCopyTemplate"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Border>
            </Grid>

            <Border StrokeShape="RoundRectangle 10" BackgroundColor="White" Padding="14"
                    Stroke="{StaticResource Gray200}">
                <VerticalStackLayout Spacing="12">

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Customer Name" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Gray700}"/>
                        <Border StrokeShape="RoundRectangle 8" Padding="10,0" Stroke="{StaticResource Gray200}"
                                BackgroundColor="{StaticResource Gray50}" HeightRequest="40">
                            <Entry x:Name="NameEntry" Placeholder="e.g. Juan dela Cruz"
                                   PlaceholderColor="{StaticResource Gray400}"
                                   TextColor="{StaticResource Gray900}"
                                   BackgroundColor="Transparent" FontSize="14"/>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Items" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Gray700}"/>
                        <Border StrokeShape="RoundRectangle 8" Padding="10" Stroke="{StaticResource Gray200}"
                                BackgroundColor="{StaticResource Gray50}">
                            <Editor x:Name="ItemsEditor" Placeholder="e.g. 2x Croissant, 1x Ube Cake"
                                    PlaceholderColor="{StaticResource Gray400}"
                                    TextColor="{StaticResource Gray900}"
                                    BackgroundColor="Transparent"
                                    AutoSize="TextChanges"
                                    HeightRequest="80" FontSize="13"/>
                        </Border>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Total Price" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Gray700}"/>
                            <Border StrokeShape="RoundRectangle 8" Padding="10,0" Stroke="{StaticResource Gray200}"
                                    BackgroundColor="{StaticResource Gray50}" HeightRequest="40">
                                <Entry x:Name="PriceEntry" Placeholder="0.00"
                                       PlaceholderColor="{StaticResource Gray400}"
                                       TextColor="{StaticResource Gray900}"
                                       BackgroundColor="Transparent"
                                       Keyboard="Numeric" FontSize="14"/>
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Contact (optional)" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Gray700}"/>
                            <Border StrokeShape="RoundRectangle 8" Padding="10,0" Stroke="{StaticResource Gray200}"
                                    BackgroundColor="{StaticResource Gray50}" HeightRequest="40">
                                <Entry x:Name="ContactEntry" Placeholder="09171234567"
                                       PlaceholderColor="{StaticResource Gray400}"
                                       TextColor="{StaticResource Gray900}"
                                       BackgroundColor="Transparent"
                                       Keyboard="Telephone" FontSize="14"/>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <Label x:Name="StatusLabel" FontSize="12" HorizontalTextAlignment="Center"/>

            <Grid HeightRequest="44" ColumnDefinitions="*, Auto" ColumnSpacing="10">
                <Grid>
                    <Button x:Name="SaveButton" Text="Create Order"
                            Clicked="OnSaveClicked"
                            BackgroundColor="{StaticResource Success}" TextColor="White"
                            FontAttributes="Bold" HeightRequest="44" FontSize="14" CornerRadius="8"/>
                    <Border x:Name="SaveLoadingOverlay" IsVisible="False"
                            StrokeShape="RoundRectangle 8" BackgroundColor="{StaticResource Success}"
                            Stroke="Transparent" HeightRequest="44">
                        <ActivityIndicator IsRunning="True" Color="White" HeightRequest="20" WidthRequest="20"/>
                    </Border>
                </Grid>
                <Button Grid.Column="1" Text="Cancel"
                        Clicked="OnCancelClicked"
                        BackgroundColor="{StaticResource Gray200}" TextColor="{StaticResource Gray700}"
                        HeightRequest="44" FontSize="13" Padding="20,0" CornerRadius="8"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
